    (hD : IsSmoothCompactlySupportedGreenDifferentialClass g D)
    (hE : IsSmoothCompactlySupportedGreenDifferentialClass g E) :
    IsSmoothCompactlySupportedGreenDifferentialClass g (D + E) := by
  rcases hD with ⟨F, hF, rfl⟩
