      (X := X) (E := ℝ) g.metric g.volume :=
    { toSection := SurfaceDifferentialField.ofCoordinateField G.gradient
      memL2 := hG }
  let dFG : SquareIntegrableSurfaceDifferentialField
      (X := X) (E := ℝ) g.metric g.volume :=
    squareIntegrableSurfaceDifferentialFieldAdd g.metric g.volume dF dG
  have hFG : SurfaceDifferentialFieldMemHilbertSchmidtL2 g.metric g.volume
      (SurfaceDifferentialField.ofCoordinateField FG.gradient) := by
    change SurfaceDifferentialFieldMemHilbertSchmidtL2 g.metric g.volume
