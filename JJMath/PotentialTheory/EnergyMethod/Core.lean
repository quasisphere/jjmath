/--
%%handwave
name:
  Completed pure classes have smooth-core approximating sequences
statement:
  Every completed pure \(H^1_0\) class is the limit of a sequence from the
  smooth compactly supported Dirichlet core.
proof:
  The core has dense image in its Hilbert completion.  Choose, for each
  \(n\), a core element within \(1/(n+1)\) of the target and squeeze the
  resulting distances to zero.
-/
theorem greenSobolevH10SmoothCompactSupport_exists_core_sequence_tendsto
    {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
    [SecondCountableTopology (SurfaceDifferentialTotalSpace X ℝ)]
    [TopologicalSpace.PseudoMetrizableSpace (SurfaceDifferentialTotalSpace X ℝ)]
    {g : BackgroundSurfaceMetricOnSurface X}
    (u : GreenSobolevH10SmoothCompactSupport g) :
    ∃ U : ℕ → (greenSobolevH10SmoothCompactSupportCore g).Core,
      Filter.Tendsto
        (fun n : ℕ ↦
          (greenSobolevH10SmoothCompactSupportCore g).toCompletion (U n))
        Filter.atTop (𝓝 u) := by
  classical
  let C := greenSobolevH10SmoothCompactSupportCore g
  have hdense : DenseRange C.toCompletion :=
    GreenSobolevH10DirichletCore.denseRange_toCompletion C
  have happrox :
      ∀ n : ℕ, ∃ v : C.Core,
        dist u (C.toCompletion v) < (1 : ℝ) / ((n : ℝ) + 1) := by
    intro n
    exact
      (Metric.denseRange_iff.mp hdense) u
        ((1 : ℝ) / ((n : ℝ) + 1)) (by positivity)
  let U : ℕ → C.Core := fun n ↦ Classical.choose (happrox n)
  have hU :
      ∀ n : ℕ,
        dist u (C.toCompletion (U n)) < (1 : ℝ) / ((n : ℝ) + 1) :=
    fun n ↦ Classical.choose_spec (happrox n)
  refine ⟨U, ?_⟩
  apply tendsto_iff_dist_tendsto_zero.mpr
  have hupper :
      Filter.Tendsto (fun n : ℕ ↦ (1 : ℝ) / ((n : ℝ) + 1))
        Filter.atTop (𝓝 0) := by
    simpa using
      (tendsto_one_div_add_atTop_nhds_zero_nat (𝕜 := ℝ))
  simpa [C] using
    (squeeze_zero
      (f := fun n : ℕ ↦ dist (C.toCompletion (U n)) u)
      (g := fun n : ℕ ↦ (1 : ℝ) / ((n : ℝ) + 1))
      (fun n : ℕ ↦ dist_nonneg)
      (fun n : ℕ ↦ le_of_lt (by
        simpa [dist_comm] using hU n))
      hupper)

/--
%%handwave
name:
  Smooth-core approximants are Cauchy in the pure Dirichlet norm
statement:
  A smooth-core sequence converging to a completed pure \(H^1_0\) class is
  Cauchy for the pure Dirichlet norm.
proof:
  Convergence in the Hilbert completion implies Cauchy convergence in the
  completion.  The canonical map from the core to its completion is an
  isometry, so the same Cauchy estimate holds in the core norm.
-/
theorem greenSobolevH10SmoothCompactSupportCore_norm_cauchy_of_tendsto_completion
    {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
    [SecondCountableTopology (SurfaceDifferentialTotalSpace X ℝ)]
    [TopologicalSpace.PseudoMetrizableSpace (SurfaceDifferentialTotalSpace X ℝ)]
    {g : BackgroundSurfaceMetricOnSurface X}
    (U : ℕ → (greenSobolevH10SmoothCompactSupportCore g).Core)
    (u : GreenSobolevH10SmoothCompactSupport g)
    (hU :
      Filter.Tendsto
        (fun n : ℕ ↦
          (greenSobolevH10SmoothCompactSupportCore g).toCompletion (U n))
        Filter.atTop (𝓝 u)) :
    ∀ ε : ℝ, 0 < ε →
      ∃ N : ℕ, ∀ n m : ℕ, N ≤ n → N ≤ m →
        ‖U n - U m‖ < ε := by
  classical
  let C := greenSobolevH10SmoothCompactSupportCore g
  intro ε hε
  have hε_half : 0 < ε / 2 := by linarith
  have hnear :
      ∀ᶠ n in Filter.atTop,
        dist (C.toCompletion (U n)) u < ε / 2 := by
    simpa [C] using Metric.tendsto_nhds.mp hU (ε / 2) hε_half
  rcases Filter.eventually_atTop.1 hnear with ⟨N, hN⟩
  refine ⟨N, ?_⟩
  intro n m hn hm
  have hn' : dist (C.toCompletion (U n)) u < ε / 2 := hN n hn
  have hm' : dist (C.toCompletion (U m)) u < ε / 2 := hN m hm
  have hdist_completion :
      dist (C.toCompletion (U n)) (C.toCompletion (U m)) < ε := by
    have htri :
        dist (C.toCompletion (U n)) (C.toCompletion (U m)) ≤
          dist (C.toCompletion (U n)) u +
            dist u (C.toCompletion (U m)) :=
      dist_triangle _ _ _
    calc
      dist (C.toCompletion (U n)) (C.toCompletion (U m)) ≤
          dist (C.toCompletion (U n)) u +
            dist u (C.toCompletion (U m)) := htri
      _ = dist (C.toCompletion (U n)) u +
            dist (C.toCompletion (U m)) u := by
        rw [dist_comm u (C.toCompletion (U m))]
      _ < ε := by linarith
  have hdist_core : dist (U n) (U m) < ε := by
    have hdist_eq :
        dist (C.toCompletion (U n)) (C.toCompletion (U m)) =
          dist (U n) (U m) := by
      change
        dist ((U n : C.Core) : UniformSpace.Completion C.Core)
          ((U m : C.Core) : UniformSpace.Completion C.Core) =
            dist (U n) (U m)
      exact UniformSpace.Completion.dist_eq (U n) (U m)
    rw [hdist_eq] at hdist_completion
    exact hdist_completion
  have hnorm_eq : ‖U n - U m‖ = dist (U n) (U m) := by
    rw [dist_eq_norm]
  exact hnorm_eq.trans_lt hdist_core

