import JJMath.PotentialTheory.EnergyMethod.PoleModel

/-!
# Energy method: Core

Pure Dirichlet core, differential representatives, and local capacity controls.
-/

namespace JJMath

open MeasureTheory
open scoped Manifold Topology ENNReal ContDiff

namespace Uniformization

/--
%%handwave
name:
  Intrinsic first-order Sobolev graph for the background area measure
statement:
  The intrinsic first-order Sobolev graph is formed from \(L^2\) functions
  and \(L^2\) cotangent fields over the background area measure, with the
  weak derivative recorded intrinsically.
-/
abbrev GreenSobolevH1IntrinsicGraph {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    (g : BackgroundSurfaceMetricOnSurface X) : Type _ := by
  letI : IsManifold SurfaceRealModel ∞ X := g.metric.isManifold_real
  letI : IsManifold SurfaceRealModel 1 X := inferInstance
  exact SobolevH1OnManifoldWithValuesIntrinsicGraphHilbertModel
    (I := SurfaceRealModel) (X := X) (E := ℝ)
    g.metric.toManifoldMetric g.volume

/--
%%handwave
name:
  Intrinsic first-order Sobolev graph is Hilbert
statement:
  The intrinsic first-order Sobolev graph associated to the background area
  measure is a real Hilbert space.
proof:
  The background area measure has smooth positive coordinate densities, so
  the general closed-graph Hilbert theorem applies.
-/
theorem greenSobolevH1IntrinsicGraph_admits_hilbert_structure {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
    [SecondCountableTopology (Bundle.TotalSpace ℝ (Bundle.Trivial X ℝ))]
    [TopologicalSpace.PseudoMetrizableSpace
      (Bundle.TotalSpace ℝ (Bundle.Trivial X ℝ))]
    [SecondCountableTopology (SurfaceDifferentialTotalSpace X ℝ)]
    [TopologicalSpace.PseudoMetrizableSpace (SurfaceDifferentialTotalSpace X ℝ)]
    (g : BackgroundSurfaceMetricOnSurface X) :
    AdmitsRealHilbertStructure (GreenSobolevH1IntrinsicGraph g) := by
  letI : IsManifold SurfaceRealModel ∞ X := g.metric.isManifold_real
  letI : IsManifold SurfaceRealModel 1 X := inferInstance
  let hμ : SmoothPositiveMeasureOnManifold (I := SurfaceRealModel) g.volume :=
    { finite_on_compact :=
        (BackgroundSurfaceMetricOnSurface.volume_smooth_positive g).finite_on_compact
      chart_density :=
        (BackgroundSurfaceMetricOnSurface.volume_smooth_positive g).chart_density }
  exact
    sobolevH1OnManifoldWithValuesIntrinsicGraph_admits_hilbert_structure_of_smoothPositiveMeasure
      (I := SurfaceRealModel) (X := X) (E := ℝ)
      g.metric.toManifoldMetric g.volume hμ

/--
%%handwave
name:
  Intrinsic zero-trace Sobolev space for the background area measure
statement:
  The intrinsic zero-trace Sobolev space is the closed linear subspace
  generated by compactly supported smooth functions inside the intrinsic
  first-order graph model.
-/
noncomputable abbrev GreenSobolevH1ZeroIntrinsic {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
    [SecondCountableTopology (Bundle.TotalSpace ℝ (Bundle.Trivial X ℝ))]
    [TopologicalSpace.PseudoMetrizableSpace
      (Bundle.TotalSpace ℝ (Bundle.Trivial X ℝ))]
    [SecondCountableTopology (SurfaceDifferentialTotalSpace X ℝ)]
    [TopologicalSpace.PseudoMetrizableSpace (SurfaceDifferentialTotalSpace X ℝ)]
    (g : BackgroundSurfaceMetricOnSurface X) : Type _ := by
  letI : IsManifold SurfaceRealModel ∞ X := g.metric.isManifold_real
  letI : IsManifold SurfaceRealModel 1 X := inferInstance
  let T := GreenSobolevH1IntrinsicGraph g
  let hT := greenSobolevH1IntrinsicGraph_admits_hilbert_structure g
  let graphNormed : NormedAddCommGroup T := Classical.choose hT
  let hT₁ := Classical.choose_spec hT
  let graphInner : InnerProductSpace ℝ T := Classical.choose hT₁
  let hT₂ := Classical.choose_spec hT₁
  let graphComplete : CompleteSpace T := Classical.choose hT₂
  letI : NormedAddCommGroup T := graphNormed
  letI : InnerProductSpace ℝ T := graphInner
  letI : CompleteSpace T := graphComplete
  exact SobolevH1ZeroOnManifoldWithValuesIntrinsicHilbertModel
    (I := SurfaceRealModel) (X := X) (E := ℝ)
    g.metric.toManifoldMetric g.volume

/--
%%handwave
name:
  Intrinsic zero-trace Sobolev space is Hilbert
statement:
  The intrinsic zero-trace Sobolev space for the background area measure is a
  real Hilbert space.
proof:
  The zero-trace space is a closed subspace of the intrinsic graph Hilbert
  space, hence is Hilbert with the induced inner product.
-/
theorem greenSobolevH1ZeroIntrinsic_admits_hilbert_structure {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
    [SecondCountableTopology (Bundle.TotalSpace ℝ (Bundle.Trivial X ℝ))]
    [TopologicalSpace.PseudoMetrizableSpace
      (Bundle.TotalSpace ℝ (Bundle.Trivial X ℝ))]
    [SecondCountableTopology (SurfaceDifferentialTotalSpace X ℝ)]
    [TopologicalSpace.PseudoMetrizableSpace (SurfaceDifferentialTotalSpace X ℝ)]
    (g : BackgroundSurfaceMetricOnSurface X) :
    AdmitsRealHilbertStructure (GreenSobolevH1ZeroIntrinsic g) := by
  letI : IsManifold SurfaceRealModel ∞ X := g.metric.isManifold_real
  letI : IsManifold SurfaceRealModel 1 X := inferInstance
  let T := GreenSobolevH1IntrinsicGraph g
  let hT := greenSobolevH1IntrinsicGraph_admits_hilbert_structure g
  let graphNormed : NormedAddCommGroup T := Classical.choose hT
  let hT₁ := Classical.choose_spec hT
  let graphInner : InnerProductSpace ℝ T := Classical.choose hT₁
  let hT₂ := Classical.choose_spec hT₁
  let graphComplete : CompleteSpace T := Classical.choose hT₂
  letI : NormedAddCommGroup T := graphNormed
  letI : InnerProductSpace ℝ T := graphInner
  letI : CompleteSpace T := graphComplete
  exact
    sobolevH1ZeroOnManifoldWithValuesIntrinsic_admits_hilbert_structure
      (I := SurfaceRealModel) (X := X) (E := ℝ)
      g.metric.toManifoldMetric g.volume

/--
%%handwave
name:
  Pure Dirichlet zero-trace \(H^1_0\) model
statement:
  A pure Dirichlet \(H^1_0\) model is a real Hilbert space whose norm is the
  Dirichlet norm of the zero-trace correction it represents.
-/
structure GreenSobolevH10DirichletModel {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    (g : BackgroundSurfaceMetricOnSurface X) where
  Space : Type
  normedAddCommGroup : NormedAddCommGroup Space
  innerProductSpace : InnerProductSpace ℝ Space
  completeSpace : CompleteSpace Space

/--
%%handwave
name:
  Pure Dirichlet zero-trace \(H^1_0\) space
statement:
  The underlying Hilbert space of a pure Dirichlet \(H^1_0\) model is the
  variational space used for the energy method.
-/
abbrev GreenSobolevH10Dirichlet {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    {g : BackgroundSurfaceMetricOnSurface X}
    (M : GreenSobolevH10DirichletModel g) : Type :=
  M.Space

noncomputable instance greenSobolevH10Dirichlet_normedAddCommGroup {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    {g : BackgroundSurfaceMetricOnSurface X}
    (M : GreenSobolevH10DirichletModel g) :
    NormedAddCommGroup (GreenSobolevH10Dirichlet M) :=
  M.normedAddCommGroup

noncomputable instance greenSobolevH10Dirichlet_innerProductSpace {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    {g : BackgroundSurfaceMetricOnSurface X}
    (M : GreenSobolevH10DirichletModel g) :
    InnerProductSpace ℝ (GreenSobolevH10Dirichlet M) :=
  M.innerProductSpace

noncomputable instance greenSobolevH10Dirichlet_completeSpace {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    {g : BackgroundSurfaceMetricOnSurface X}
    (M : GreenSobolevH10DirichletModel g) :
    CompleteSpace (GreenSobolevH10Dirichlet M) :=
  M.completeSpace

/--
%%handwave
name:
  Pure Dirichlet pre-Hilbert core
statement:
  A pure Dirichlet core is a pre-Hilbert realization of compactly supported
  zero-trace data before Hilbert completion.
-/
structure GreenSobolevH10DirichletCore {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    (g : BackgroundSurfaceMetricOnSurface X) where
  Core : Type
  normedAddCommGroup : NormedAddCommGroup Core
  innerProductSpace : InnerProductSpace ℝ Core

noncomputable instance greenSobolevH10DirichletCore_normedAddCommGroup
    {X : Type} [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    {g : BackgroundSurfaceMetricOnSurface X}
    (C : GreenSobolevH10DirichletCore g) :
    NormedAddCommGroup C.Core :=
  C.normedAddCommGroup

noncomputable instance greenSobolevH10DirichletCore_innerProductSpace
    {X : Type} [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    {g : BackgroundSurfaceMetricOnSurface X}
    (C : GreenSobolevH10DirichletCore g) :
    InnerProductSpace ℝ C.Core :=
  C.innerProductSpace

/--
%%handwave
name:
  Pure Dirichlet completion
statement:
  The pure Dirichlet \(H^1_0\) space associated to a pre-Hilbert core is the
  Hilbert completion of that core.
-/
abbrev GreenSobolevH10DirichletCompletion {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    {g : BackgroundSurfaceMetricOnSurface X}
    (C : GreenSobolevH10DirichletCore g) : Type :=
  UniformSpace.Completion C.Core

/--
%%handwave
name:
  Completion model for pure \(H^1_0\)
statement:
  Completing a pure Dirichlet pre-Hilbert core gives a Hilbert model for
  \(H^1_0\).
-/
noncomputable def GreenSobolevH10DirichletModel.ofCore {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    {g : BackgroundSurfaceMetricOnSurface X}
    (C : GreenSobolevH10DirichletCore g) :
    GreenSobolevH10DirichletModel g := by
  letI : NormedAddCommGroup C.Core := C.normedAddCommGroup
  letI : InnerProductSpace ℝ C.Core := C.innerProductSpace
  exact
    { Space := GreenSobolevH10DirichletCompletion C
      normedAddCommGroup := inferInstance
      innerProductSpace := inferInstance
      completeSpace := inferInstance }

/--
%%handwave
name:
  Core inclusion into pure \(H^1_0\)
statement:
  A core element determines an element of the completed pure Dirichlet
  \(H^1_0\) space.
-/
noncomputable def GreenSobolevH10DirichletCore.toCompletion {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    {g : BackgroundSurfaceMetricOnSurface X}
    (C : GreenSobolevH10DirichletCore g) :
    C.Core → GreenSobolevH10DirichletCompletion C := by
  letI : NormedAddCommGroup C.Core := C.normedAddCommGroup
  exact fun u ↦ (u : UniformSpace.Completion C.Core)

/--
%%handwave
name:
  Core inclusion preserves the Dirichlet norm
statement:
  The canonical inclusion of the pre-Hilbert core into its completion
  preserves the norm.
-/
theorem GreenSobolevH10DirichletCore.norm_toCompletion {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    {g : BackgroundSurfaceMetricOnSurface X}
    (C : GreenSobolevH10DirichletCore g) (u : C.Core) :
    ‖C.toCompletion u‖ = ‖u‖ := by
  letI : NormedAddCommGroup C.Core := C.normedAddCommGroup
  exact UniformSpace.Completion.norm_coe u

/--
%%handwave
name:
  Core inclusion preserves squared Dirichlet norm
statement:
  The squared norm of a core element is unchanged after passing to the pure
  Dirichlet completion.
-/
theorem GreenSobolevH10DirichletCore.normSq_toCompletion {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    {g : BackgroundSurfaceMetricOnSurface X}
    (C : GreenSobolevH10DirichletCore g) (u : C.Core) :
    ‖C.toCompletion u‖ ^ (2 : ℕ) = ‖u‖ ^ (2 : ℕ) := by
  rw [C.norm_toCompletion u]

/--
%%handwave
name:
  Completed pure Dirichlet space is Hilbert
statement:
  The completion of a pure Dirichlet pre-Hilbert core is a real Hilbert
  space.
-/
theorem greenSobolevH10DirichletCompletion_admits_hilbert_structure {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    {g : BackgroundSurfaceMetricOnSurface X}
    (C : GreenSobolevH10DirichletCore g) :
    AdmitsRealHilbertStructure (GreenSobolevH10DirichletCompletion C) := by
  letI : NormedAddCommGroup C.Core := C.normedAddCommGroup
  letI : InnerProductSpace ℝ C.Core := C.innerProductSpace
  refine ⟨inferInstance, inferInstance, inferInstance, ?_⟩
  exact ⟨HilbertSpace.mk⟩

/--
%%handwave
name:
  Core inclusion has dense range
statement:
  The image of the pre-Hilbert core is dense in the completed pure Dirichlet
  space.
-/
theorem GreenSobolevH10DirichletCore.denseRange_toCompletion {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    {g : BackgroundSurfaceMetricOnSurface X}
    (C : GreenSobolevH10DirichletCore g) :
    DenseRange C.toCompletion := by
  letI : NormedAddCommGroup C.Core := C.normedAddCommGroup
  simpa [GreenSobolevH10DirichletCore.toCompletion] using
    (UniformSpace.Completion.denseRange_coe : DenseRange
      ((↑) : C.Core → UniformSpace.Completion C.Core))

/--
%%handwave
name:
  Core inclusion induces the completion uniformity
statement:
  The canonical map from the pure Dirichlet core to its completion is a
  uniform inducing map.
-/
theorem GreenSobolevH10DirichletCore.isUniformInducing_toCompletion {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    {g : BackgroundSurfaceMetricOnSurface X}
    (C : GreenSobolevH10DirichletCore g) :
    IsUniformInducing C.toCompletion := by
  letI : NormedAddCommGroup C.Core := C.normedAddCommGroup
  simpa [GreenSobolevH10DirichletCore.toCompletion] using
    (UniformSpace.Completion.isUniformInducing_coe C.Core)

/--
%%handwave
name:
  Extend a bounded source functional to pure \(H^1_0\)
statement:
  A continuous linear source pairing on the pre-Hilbert core extends
  uniquely to the completed pure Dirichlet space.
-/
noncomputable def GreenSobolevH10DirichletCore.extendSource {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    {g : BackgroundSurfaceMetricOnSurface X}
    (C : GreenSobolevH10DirichletCore g)
    (source : C.Core →L[ℝ] ℝ) :
    GreenSobolevH10DirichletCompletion C →L[ℝ] ℝ := by
  letI : NormedAddCommGroup C.Core := C.normedAddCommGroup
  letI : InnerProductSpace ℝ C.Core := C.innerProductSpace
  exact source.extend
    (UniformSpace.Completion.toComplL :
      C.Core →L[ℝ] UniformSpace.Completion C.Core)

/--
%%handwave
name:
  Extended source agrees on the core
statement:
  The continuous extension of a source functional agrees with the original
  pairing on core elements.
-/
theorem GreenSobolevH10DirichletCore.extendSource_toCompletion {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    {g : BackgroundSurfaceMetricOnSurface X}
    (C : GreenSobolevH10DirichletCore g)
    (source : C.Core →L[ℝ] ℝ) (u : C.Core) :
    C.extendSource source (C.toCompletion u) = source u := by
  letI : NormedAddCommGroup C.Core := C.normedAddCommGroup
  letI : InnerProductSpace ℝ C.Core := C.innerProductSpace
  dsimp [GreenSobolevH10DirichletCore.extendSource,
    GreenSobolevH10DirichletCore.toCompletion]
  exact ContinuousLinearMap.extend_eq source
    (by
      simpa using
        (UniformSpace.Completion.denseRange_coe : DenseRange
          ((↑) : C.Core → UniformSpace.Completion C.Core)))
    (UniformSpace.Completion.isUniformInducing_coe C.Core) u

/--
%%handwave
name:
  Extended source is bounded by the pure Dirichlet norm
statement:
  The extension of a continuous source functional to pure \(H^1_0\) is
  bounded by its operator norm times the \(H^1_0\) norm.
-/
theorem GreenSobolevH10DirichletCore.extendSource_bound {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    {g : BackgroundSurfaceMetricOnSurface X}
    (C : GreenSobolevH10DirichletCore g)
    (source : C.Core →L[ℝ] ℝ)
    (u : GreenSobolevH10DirichletCompletion C) :
    C.extendSource source u ≤ ‖C.extendSource source‖ * ‖u‖ := by
  have hnorm :
      ‖C.extendSource source u‖ ≤ ‖C.extendSource source‖ * ‖u‖ :=
    ContinuousLinearMap.le_opNorm _ _
  exact (le_abs_self _).trans (by simpa [Real.norm_eq_abs] using hnorm)

/--
%%handwave
name:
  Intrinsic \(L^2\) cotangent fields for the background metric
statement:
  The intrinsic differential \(L^2\) space is the Hilbert space of
  square-integrable cotangent fields for the background metric and area
  measure.
-/
abbrev GreenDifferentialL2Intrinsic {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    (g : BackgroundSurfaceMetricOnSurface X) : Type _ := by
  letI : IsManifold SurfaceRealModel ∞ X := g.metric.isManifold_real
  letI : IsManifold SurfaceRealModel 1 X := inferInstance
  exact SurfaceDifferentialL2Section (X := X) (E := ℝ) g.metric g.volume

/--
%%handwave
name:
  Intrinsic \(L^2\) cotangent fields form a Hilbert space
statement:
  The intrinsic \(L^2\) cotangent fields for the background metric and area
  measure form a real Hilbert space.
-/
theorem greenDifferentialL2Intrinsic_admits_hilbert_structure {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
    [SecondCountableTopology (SurfaceDifferentialTotalSpace X ℝ)]
    [TopologicalSpace.PseudoMetrizableSpace (SurfaceDifferentialTotalSpace X ℝ)]
    (g : BackgroundSurfaceMetricOnSurface X) :
    AdmitsRealHilbertStructure (GreenDifferentialL2Intrinsic g) := by
  letI : IsManifold SurfaceRealModel ∞ X := g.metric.isManifold_real
  exact surfaceDifferentialL2Sections_admit_hilbert_structure
    (X := X) (E := ℝ) g.metric g.volume

noncomputable instance greenDifferentialL2Intrinsic_normedAddCommGroup {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
    [SecondCountableTopology (SurfaceDifferentialTotalSpace X ℝ)]
    [TopologicalSpace.PseudoMetrizableSpace (SurfaceDifferentialTotalSpace X ℝ)]
    (g : BackgroundSurfaceMetricOnSurface X) :
    NormedAddCommGroup (GreenDifferentialL2Intrinsic g) := by
  let metric :=
    manifoldDifferentialHilbertSchmidtContinuousRiemannianMetric
      (I := SurfaceRealModel) (X := X) (E := ℝ) g.metric.toManifoldMetric
  letI : Bundle.RiemannianBundle
      (ManifoldDifferentialBundleFiber
        (I := SurfaceRealModel) (X := X) (E := ℝ)) :=
    ⟨metric.toRiemannianMetric⟩
  letI (x : X) :
      NormedAddCommGroup
        (ManifoldDifferentialBundleFiber
          (I := SurfaceRealModel) (X := X) (E := ℝ) x) :=
    manifoldDifferentialHilbertSchmidtNormedAddCommGroup
      (I := SurfaceRealModel) (X := X) (E := ℝ) metric x
  letI (x : X) :
      InnerProductSpace ℝ
        (ManifoldDifferentialBundleFiber
          (I := SurfaceRealModel) (X := X) (E := ℝ) x) :=
    manifoldDifferentialHilbertSchmidtInnerProductSpace
      (I := SurfaceRealModel) (X := X) (E := ℝ) metric x
  exact
    manifoldDifferentialL2SectionNormedAddCommGroup
      (I := SurfaceRealModel) (X := X) (E := ℝ)
      g.metric.toManifoldMetric g.volume

noncomputable instance greenDifferentialL2Intrinsic_innerProductSpace {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
    [SecondCountableTopology (SurfaceDifferentialTotalSpace X ℝ)]
    [TopologicalSpace.PseudoMetrizableSpace (SurfaceDifferentialTotalSpace X ℝ)]
    (g : BackgroundSurfaceMetricOnSurface X) :
    InnerProductSpace ℝ (GreenDifferentialL2Intrinsic g) := by
  let metric :=
    manifoldDifferentialHilbertSchmidtContinuousRiemannianMetric
      (I := SurfaceRealModel) (X := X) (E := ℝ) g.metric.toManifoldMetric
  letI : Bundle.RiemannianBundle
      (ManifoldDifferentialBundleFiber
        (I := SurfaceRealModel) (X := X) (E := ℝ)) :=
    ⟨metric.toRiemannianMetric⟩
  letI (x : X) :
      NormedAddCommGroup
        (ManifoldDifferentialBundleFiber
          (I := SurfaceRealModel) (X := X) (E := ℝ) x) :=
    manifoldDifferentialHilbertSchmidtNormedAddCommGroup
      (I := SurfaceRealModel) (X := X) (E := ℝ) metric x
  letI (x : X) :
      InnerProductSpace ℝ
        (ManifoldDifferentialBundleFiber
          (I := SurfaceRealModel) (X := X) (E := ℝ) x) :=
    manifoldDifferentialHilbertSchmidtInnerProductSpace
      (I := SurfaceRealModel) (X := X) (E := ℝ) metric x
  letI : NormedAddCommGroup (GreenDifferentialL2Intrinsic g) :=
    greenDifferentialL2Intrinsic_normedAddCommGroup g
  exact
    l2HilbertBundleInnerProductSpace
      (I := SurfaceRealModel)
      (G := manifoldDifferentialHilbertBundleGeometry
        (I := SurfaceRealModel) (X := X) (E := ℝ) g.metric.toManifoldMetric)
      (μ := g.volume) (fun _ _ _ ↦ rfl)

noncomputable instance greenDifferentialL2Intrinsic_completeSpace {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
    [SecondCountableTopology (SurfaceDifferentialTotalSpace X ℝ)]
    [TopologicalSpace.PseudoMetrizableSpace (SurfaceDifferentialTotalSpace X ℝ)]
    (g : BackgroundSurfaceMetricOnSurface X) :
    CompleteSpace (GreenDifferentialL2Intrinsic g) := by
  let metric :=
    manifoldDifferentialHilbertSchmidtContinuousRiemannianMetric
      (I := SurfaceRealModel) (X := X) (E := ℝ) g.metric.toManifoldMetric
  letI : Bundle.RiemannianBundle
      (ManifoldDifferentialBundleFiber
        (I := SurfaceRealModel) (X := X) (E := ℝ)) :=
    ⟨metric.toRiemannianMetric⟩
  letI (x : X) :
      NormedAddCommGroup
        (ManifoldDifferentialBundleFiber
          (I := SurfaceRealModel) (X := X) (E := ℝ) x) :=
    manifoldDifferentialHilbertSchmidtNormedAddCommGroup
      (I := SurfaceRealModel) (X := X) (E := ℝ) metric x
  letI (x : X) :
      InnerProductSpace ℝ
        (ManifoldDifferentialBundleFiber
          (I := SurfaceRealModel) (X := X) (E := ℝ) x) :=
    manifoldDifferentialHilbertSchmidtInnerProductSpace
      (I := SurfaceRealModel) (X := X) (E := ℝ) metric x
  let Vd :=
    ManifoldDifferentialBundleFiber
      (I := SurfaceRealModel) (X := X) (E := ℝ)
  let diffFiberCompletePseudo :
      ∀ x : X, @CompleteSpace (Vd x) PseudoMetricSpace.toUniformSpace :=
    fun x ↦ by
      let U0 : UniformSpace (Vd x) :=
        ContinuousLinearMap.uniformSpace
          (𝕜₁ := ℝ) (𝕜₂ := ℝ) (σ := RingHom.id ℝ)
          (E := TangentSpace SurfaceRealModel x) (F := ℝ)
      have hU : PseudoMetricSpace.toUniformSpace = U0 := by
        apply UniformSpace.ext
        rw [@uniformity_eq_comap_nhds_zero (Vd x)
          PseudoMetricSpace.toUniformSpace inferInstance inferInstance]
        letI : UniformSpace (Vd x) := U0
        rw [@uniformity_eq_comap_nhds_zero (Vd x)
          U0 inferInstance inferInstance]
      change @CompleteSpace (Vd x) PseudoMetricSpace.toUniformSpace
      rw [hU]
      change CompleteSpace (ℂ →L[ℝ] ℝ)
      infer_instance
  exact @l2HilbertBundle_completeSpace_core
    ℂ X (ℂ →L[ℝ] ℝ)
    inferInstance inferInstance
    SurfaceRealModel inferInstance inferInstance inferInstance inferInstance
    inferInstance inferInstance
    inferInstance inferInstance inferInstance
    Vd inferInstance inferInstance inferInstance
    (fun x ↦ manifoldDifferentialHilbertSchmidtNormedAddCommGroup
      (I := SurfaceRealModel) (X := X) (E := ℝ) metric x)
    (fun x ↦ manifoldDifferentialHilbertSchmidtInnerProductSpace
      (I := SurfaceRealModel) (X := X) (E := ℝ) metric x)
    diffFiberCompletePseudo
    inferInstance inferInstance inferInstance
    (manifoldDifferentialHilbertBundleGeometry
      (I := SurfaceRealModel) (X := X) (E := ℝ) g.metric.toManifoldMetric)
    g.volume (by intro x A B; rfl)

/--
%%handwave
name:
  Smooth compactly supported differential class
statement:
  An intrinsic \(L^2\) cotangent class is generated by a compactly supported
  smooth function if it has a representative equal to the classical
  differential of that function.
-/
def IsSmoothCompactlySupportedGreenDifferentialClass {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
    [SecondCountableTopology (SurfaceDifferentialTotalSpace X ℝ)]
    [TopologicalSpace.PseudoMetrizableSpace (SurfaceDifferentialTotalSpace X ℝ)]
    (g : BackgroundSurfaceMetricOnSurface X)
    (D : GreenDifferentialL2Intrinsic g) : Prop :=
  ∃ F : SmoothCompactlySupportedGlobalSurfaceFunction X,
  ∃ hF :
      SurfaceDifferentialFieldMemHilbertSchmidtL2 g.metric g.volume
        (SurfaceDifferentialField.ofCoordinateField F.gradient),
    (Quotient.mk
        (SquareIntegrableSurfaceDifferentialField.aeSetoid
          (X := X) (E := ℝ) (g := g.metric) (μ := g.volume))
        ({ toSection := SurfaceDifferentialField.ofCoordinateField F.gradient
           memL2 := hF } :
          SquareIntegrableSurfaceDifferentialField
            (X := X) (E := ℝ) g.metric g.volume) :
      GreenDifferentialL2Intrinsic g) = D

/--
%%handwave
name:
  Smooth compactly supported Dirichlet core subspace
statement:
  The raw pure Dirichlet core is the real span, inside \(L^2(T^\ast X)\), of
  differentials of compactly supported smooth functions.
-/
noncomputable def greenSobolevH10SmoothCompactSupportCoreSubmodule {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
    [SecondCountableTopology (SurfaceDifferentialTotalSpace X ℝ)]
    [TopologicalSpace.PseudoMetrizableSpace (SurfaceDifferentialTotalSpace X ℝ)]
    (g : BackgroundSurfaceMetricOnSurface X) :
    Submodule ℝ (GreenDifferentialL2Intrinsic g) :=
  Submodule.span ℝ {D : GreenDifferentialL2Intrinsic g |
    IsSmoothCompactlySupportedGreenDifferentialClass g D}

/--
%%handwave
name:
  Smooth compactly supported Dirichlet core
statement:
  The concrete pure Dirichlet core is the pre-Hilbert subspace of
  \(L^2\)-cotangent fields spanned by compactly supported smooth
  differentials.
-/
noncomputable def greenSobolevH10SmoothCompactSupportCore {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
    [SecondCountableTopology (SurfaceDifferentialTotalSpace X ℝ)]
    [TopologicalSpace.PseudoMetrizableSpace (SurfaceDifferentialTotalSpace X ℝ)]
    (g : BackgroundSurfaceMetricOnSurface X) :
    GreenSobolevH10DirichletCore g :=
  { Core := greenSobolevH10SmoothCompactSupportCoreSubmodule g
    normedAddCommGroup := inferInstance
    innerProductSpace := inferInstance }

/--
%%handwave
name:
  Concrete pure \(H^1_0\) space
statement:
  The concrete pure \(H^1_0\) space is the Hilbert completion of the span of
  compactly supported smooth differentials in \(L^2(T^\ast X)\).
-/
abbrev GreenSobolevH10SmoothCompactSupport {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
    [SecondCountableTopology (SurfaceDifferentialTotalSpace X ℝ)]
    [TopologicalSpace.PseudoMetrizableSpace (SurfaceDifferentialTotalSpace X ℝ)]
    (g : BackgroundSurfaceMetricOnSurface X) : Type :=
  GreenSobolevH10DirichletCompletion
    (greenSobolevH10SmoothCompactSupportCore g)

/--
%%handwave
name:
  Concrete pure \(H^1_0\) model
statement:
  The completed smooth compactly supported Dirichlet core gives a pure
  \(H^1_0\) Hilbert model.
-/
noncomputable def greenSobolevH10SmoothCompactSupportModel {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
    [SecondCountableTopology (SurfaceDifferentialTotalSpace X ℝ)]
    [TopologicalSpace.PseudoMetrizableSpace (SurfaceDifferentialTotalSpace X ℝ)]
    (g : BackgroundSurfaceMetricOnSurface X) :
    GreenSobolevH10DirichletModel g :=
  GreenSobolevH10DirichletModel.ofCore
    (greenSobolevH10SmoothCompactSupportCore g)

/--
%%handwave
name:
  Smooth compactly supported generators belong to the core
statement:
  Every compactly supported smooth differential class belongs to the concrete
  Dirichlet core.
-/
theorem smoothCompactlySupportedGreenDifferentialClass_mem_core {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
