      manifoldDifferentialHilbertSchmidtNormedAddCommGroup
        (I := SurfaceRealModel) (X := X) (E := ℝ) metric x
    letI (x : X) :
        InnerProductSpace ℝ
          (ManifoldDifferentialBundleFiber
            (I := SurfaceRealModel) (X := X) (E := ℝ) x) :=
      manifoldDifferentialHilbertSchmidtInnerProductSpace
        (I := SurfaceRealModel) (X := X) (E := ℝ) metric x
    have hmk :=
      l2HilbertBundle_mk_add
        (I := SurfaceRealModel)
        (G := manifoldDifferentialHilbertBundleGeometry
          (I := SurfaceRealModel) (X := X) (E := ℝ)
          g.metric.toManifoldMetric)
        (μ := g.volume) (fun _ _ _ ↦ rfl) dF dG
    simpa [dFG, squareIntegrableSurfaceDifferentialFieldAdd,
      greenDifferentialL2Intrinsic_normedAddCommGroup,
      greenDifferentialL2Intrinsic_admits_hilbert_structure,
      surfaceDifferentialL2Sections_admit_hilbert_structure] using hmk

