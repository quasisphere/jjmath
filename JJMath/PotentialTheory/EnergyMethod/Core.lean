    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
    [SecondCountableTopology (Bundle.TotalSpace ℝ (Bundle.Trivial X ℝ))]
    [TopologicalSpace.PseudoMetrizableSpace
      (Bundle.TotalSpace ℝ (Bundle.Trivial X ℝ))]
    [SecondCountableTopology (SurfaceDifferentialTotalSpace X ℝ)]
    [TopologicalSpace.PseudoMetrizableSpace (SurfaceDifferentialTotalSpace X ℝ)]
    (g : BackgroundSurfaceMetricOnSurface X) :
    NormedAddCommGroup (GreenSobolevH1ZeroIntrinsic g) :=
  inferInstance

noncomputable instance greenSobolevH1ZeroIntrinsic_innerProductSpace {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
    [SecondCountableTopology (Bundle.TotalSpace ℝ (Bundle.Trivial X ℝ))]
    [TopologicalSpace.PseudoMetrizableSpace
      (Bundle.TotalSpace ℝ (Bundle.Trivial X ℝ))]
    [SecondCountableTopology (SurfaceDifferentialTotalSpace X ℝ)]
    [TopologicalSpace.PseudoMetrizableSpace (SurfaceDifferentialTotalSpace X ℝ)]
    (g : BackgroundSurfaceMetricOnSurface X) :
    InnerProductSpace ℝ (GreenSobolevH1ZeroIntrinsic g) :=
  inferInstance

noncomputable instance greenSobolevH1ZeroIntrinsic_completeSpace {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
    [SecondCountableTopology (Bundle.TotalSpace ℝ (Bundle.Trivial X ℝ))]
    [TopologicalSpace.PseudoMetrizableSpace
      (Bundle.TotalSpace ℝ (Bundle.Trivial X ℝ))]
    [SecondCountableTopology (SurfaceDifferentialTotalSpace X ℝ)]
    [TopologicalSpace.PseudoMetrizableSpace (SurfaceDifferentialTotalSpace X ℝ)]
    (g : BackgroundSurfaceMetricOnSurface X) :
    CompleteSpace (GreenSobolevH1ZeroIntrinsic g) := by
  letI : IsManifold SurfaceRealModel 1 X := inferInstance
  let T := GreenSobolevH1IntrinsicGraph g
  let K : Submodule ℝ T :=
    (SobolevH1ZeroOnManifoldWithValuesIntrinsicClosedSubmodule
      (I := SurfaceRealModel) (X := X) (E := ℝ)
      g.metric.toManifoldMetric g.volume :
      Submodule ℝ T)
  have hK_closed : IsClosed (K : Set T) := by
    simpa [K, T, GreenSobolevH1IntrinsicGraph] using
      sobolevH1ZeroOnManifoldWithValuesIntrinsic_isClosed
        (I := SurfaceRealModel) (X := X) (E := ℝ)
        g.metric.toManifoldMetric g.volume
  haveI : IsClosed (K : Set T) := hK_closed
  change CompleteSpace K
  infer_instance

/--
%%handwave
name:
  Pure Dirichlet capacity at infinity
statement:
  Pure Dirichlet capacity at infinity says that, on each compact set, the
  local \(L^2\) mass of every compactly supported smooth scalar function is
  controlled by the pure Dirichlet energy of that function.
-/
def HasPureDirichletCapacityAtInfinity {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    (g : BackgroundSurfaceMetricOnSurface X) : Prop :=
  ∀ K : Set X, IsCompact K →
    ∃ P : ℝ, 0 ≤ P ∧ ∀ F : SmoothCompactlySupportedGlobalSurfaceFunction X,
      ∫ x in K, ‖F.toFun x‖ ^ (2 : ℕ) ∂g.volume ≤
        P * ∫ x, g.gradientInner x (F.gradient x) (F.gradient x) ∂g.volume

/--
%%handwave
name:
  Compact source pairings with smooth tests are integrable
statement:
  A smooth compactly supported source has an integrable product with every
  compactly supported smooth test function.
proof:
  Restrict to the compact support of the source. Both factors are bounded on
  this compact set, hence square-integrable there, and their product is
  integrable. The product vanishes outside the source support.
-/
theorem compactly_supported_smooth_source_mul_smooth_integrable
    {X : Type} [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    [BorelSpace X]
    {g : BackgroundSurfaceMetricOnSurface X} {source : X → ℝ}
    (hsource_compact : HasCompactSupportOnSurface source)
    (hsource_smooth : IsSmoothOnSurface (Set.univ : Set X) source)
    (F : SmoothCompactlySupportedGlobalSurfaceFunction X) :
    Integrable (fun x ↦ source x * F.toFun x) g.volume := by
  classical
  let K : Set X := tsupport source
  let μK : Measure X := g.volume.restrict K
  have hK_compact : IsCompact K := by
    simpa [HasCompactSupportOnSurface, K, tsupport, Function.support] using
      hsource_compact
  haveI : IsFiniteMeasureOnCompacts g.volume :=
    BackgroundSurfaceMetricOnSurface.volume_isFiniteMeasureOnCompacts g
  have hK_ne_top : g.volume K ≠ (∞ : ℝ≥0∞) := hK_compact.measure_ne_top
  haveI : IsFiniteMeasure μK := by
    dsimp [μK]
    exact isFiniteMeasure_restrict.2 hK_ne_top
  have hsource_cont : Continuous source :=
    isSmoothOnSurface_univ_continuous hsource_smooth
  have hsource_aesm : AEStronglyMeasurable source μK :=
    hsource_cont.aestronglyMeasurable
  rcases hK_compact.exists_bound_of_continuousOn hsource_cont.continuousOn with
    ⟨C0, hC0⟩
  let C : ℝ := max C0 0
  have hC_bound : ∀ x : X, ‖source x‖ ≤ C := by
    intro x
    by_cases hx : x ∈ K
    · exact (hC0 x hx).trans (le_max_left C0 0)
    · have hx_not_tsupport : x ∉ tsupport source := by
        simpa [K] using hx
      have hx_zero : source x = 0 :=
        image_eq_zero_of_notMem_tsupport hx_not_tsupport
      simp [hx_zero, C]
  have hsource_mem : MemLp source (2 : ℝ≥0∞) μK := by
    exact MemLp.of_bound (p := (2 : ℝ≥0∞)) hsource_aesm C
      (Filter.Eventually.of_forall hC_bound)
  have hF_cont : Continuous F.toFun :=
    isSmoothOnSurface_univ_continuous F.smooth
  have hF_aesm : AEStronglyMeasurable F.toFun μK :=
    hF_cont.aestronglyMeasurable
  let KF : Set X := tsupport F.toFun
  have hKF_compact : IsCompact KF := by
    simpa [HasCompactSupportOnSurface, HasCompactSupport, KF, tsupport,
      Function.support] using F.compact_support
  rcases hKF_compact.exists_bound_of_continuousOn hF_cont.continuousOn with
    ⟨B0, hB0⟩
  let B : ℝ := max B0 0
  have hB_bound : ∀ x : X, ‖F.toFun x‖ ≤ B := by
    intro x
    by_cases hx : x ∈ KF
    · exact (hB0 x hx).trans (le_max_left B0 0)
    · have hx_not_tsupport : x ∉ tsupport F.toFun := by
        simpa [KF] using hx
      have hx_zero : F.toFun x = 0 :=
        image_eq_zero_of_notMem_tsupport hx_not_tsupport
      simp [hx_zero, B]
  have hF_mem : MemLp F.toFun (2 : ℝ≥0∞) μK := by
    exact MemLp.of_bound (p := (2 : ℝ≥0∞)) hF_aesm B
      (Filter.Eventually.of_forall hB_bound)
  have hprodK : Integrable (fun x ↦ source x * F.toFun x) μK :=
    MemLp.integrable_mul hsource_mem hF_mem
  have hsupport : Function.support (fun x ↦ source x * F.toFun x) ⊆ K := by
    intro x hx
    have hsource_ne : source x ≠ 0 := by
      intro hzero
      exact hx (by simp [hzero])
    exact subset_tsupport source hsource_ne
  exact (integrableOn_iff_integrable_of_support_subset hsupport).mp
    (by simpa [IntegrableOn, μK] using hprodK)

theorem compactly_supported_smooth_source_pairing_add
    {X : Type} [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    [BorelSpace X]
    {g : BackgroundSurfaceMetricOnSurface X} {source : X → ℝ}
    (hsource_compact : HasCompactSupportOnSurface source)
    (hsource_smooth : IsSmoothOnSurface (Set.univ : Set X) source)
    (F G : SmoothCompactlySupportedGlobalSurfaceFunction X) :
    ∫ x, source x *
        (SmoothCompactlySupportedGlobalSurfaceFunction.add F G).toFun x
        ∂g.volume =
      ∫ x, source x * F.toFun x ∂g.volume +
        ∫ x, source x * G.toFun x ∂g.volume := by
  have hF :
      Integrable (fun x ↦ source x * F.toFun x) g.volume :=
    compactly_supported_smooth_source_mul_smooth_integrable
      hsource_compact hsource_smooth F
  have hG :
      Integrable (fun x ↦ source x * G.toFun x) g.volume :=
    compactly_supported_smooth_source_mul_smooth_integrable
      hsource_compact hsource_smooth G
  calc
    ∫ x, source x *
        (SmoothCompactlySupportedGlobalSurfaceFunction.add F G).toFun x
        ∂g.volume =
        ∫ x, (source x * F.toFun x) + (source x * G.toFun x) ∂g.volume := by
      apply integral_congr_ae
      filter_upwards [] with x
      simp [SmoothCompactlySupportedGlobalSurfaceFunction.add, mul_add]
    _ = ∫ x, source x * F.toFun x ∂g.volume +
        ∫ x, source x * G.toFun x ∂g.volume := by
      rw [integral_add hF hG]

theorem compactly_supported_smooth_source_pairing_smul
    {X : Type} [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    [BorelSpace X]
    {g : BackgroundSurfaceMetricOnSurface X} {source : X → ℝ}
    (hsource_compact : HasCompactSupportOnSurface source)
    (hsource_smooth : IsSmoothOnSurface (Set.univ : Set X) source)
    (c : ℝ) (F : SmoothCompactlySupportedGlobalSurfaceFunction X) :
    ∫ x, source x *
        (SmoothCompactlySupportedGlobalSurfaceFunction.smul c F).toFun x
        ∂g.volume =
      c * ∫ x, source x * F.toFun x ∂g.volume := by
  have hF :
      Integrable (fun x ↦ source x * F.toFun x) g.volume :=
    compactly_supported_smooth_source_mul_smooth_integrable
      hsource_compact hsource_smooth F
  calc
    ∫ x, source x *
        (SmoothCompactlySupportedGlobalSurfaceFunction.smul c F).toFun x
        ∂g.volume =
        ∫ x, c * (source x * F.toFun x) ∂g.volume := by
      apply integral_congr_ae
      filter_upwards [] with x
      simp [SmoothCompactlySupportedGlobalSurfaceFunction.smul, mul_left_comm]
    _ = c * ∫ x, source x * F.toFun x ∂g.volume := by
      rw [integral_const_mul]

/--
%%handwave
name:
  Compact source pairing with a smooth test is controlled by local \(L^2\)
statement:
  A smooth compactly supported source pairs with a compactly supported smooth
  function by at most a constant times the local \(L^2\)-norm of the function
  on the source support.
proof:
  Localize the integral to the compact support of the source. Both factors
  are bounded and square-integrable there, and Cauchy--Schwarz gives the
  estimate.
-/
theorem compactly_supported_smooth_source_abs_pairing_smooth_le_const_mul_sqrt_localL2
    {X : Type} [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    [BorelSpace X]
    {g : BackgroundSurfaceMetricOnSurface X} {source : X → ℝ}
    (hsource_compact : HasCompactSupportOnSurface source)
    (hsource_smooth : IsSmoothOnSurface (Set.univ : Set X) source) :
    ∃ A : ℝ, 0 ≤ A ∧
      ∀ F : SmoothCompactlySupportedGlobalSurfaceFunction X,
        |∫ x, source x * F.toFun x ∂g.volume| ≤
          A * Real.sqrt
            (∫ x in closure {x : X | source x ≠ 0},
              ‖F.toFun x‖ ^ (2 : ℕ) ∂g.volume) := by
  classical
  let K : Set X := tsupport source
  let μK : Measure X := g.volume.restrict K
  have hK_compact : IsCompact K := by
    simpa [HasCompactSupportOnSurface, K, tsupport, Function.support] using
      hsource_compact
  haveI : IsFiniteMeasureOnCompacts g.volume :=
    BackgroundSurfaceMetricOnSurface.volume_isFiniteMeasureOnCompacts g
  have hK_ne_top : g.volume K ≠ (∞ : ℝ≥0∞) := hK_compact.measure_ne_top
  haveI : IsFiniteMeasure μK := by
    dsimp [μK]
    exact isFiniteMeasure_restrict.2 hK_ne_top
  have hsource_cont : Continuous source :=
    isSmoothOnSurface_univ_continuous hsource_smooth
  have hsource_aesm : AEStronglyMeasurable source μK :=
    hsource_cont.aestronglyMeasurable
  rcases hK_compact.exists_bound_of_continuousOn hsource_cont.continuousOn with
    ⟨C0, hC0⟩
  let C : ℝ := max C0 0
  have hC_bound : ∀ x : X, ‖source x‖ ≤ C := by
    intro x
    by_cases hx : x ∈ K
    · exact (hC0 x hx).trans (le_max_left C0 0)
    · have hx_not_tsupport : x ∉ tsupport source := by
        simpa [K] using hx
      have hx_zero : source x = 0 :=
        image_eq_zero_of_notMem_tsupport hx_not_tsupport
      simp [hx_zero, C]
  have hsource_mem : MemLp source (ENNReal.ofReal (2 : ℝ)) μK := by
    exact MemLp.of_bound (p := ENNReal.ofReal (2 : ℝ)) hsource_aesm C
      (Filter.Eventually.of_forall hC_bound)
  let A : ℝ := Real.sqrt (∫ x, ‖source x‖ ^ (2 : ℝ) ∂μK)
  refine ⟨A, Real.sqrt_nonneg _, ?_⟩
  intro F
  have hF_cont : Continuous F.toFun :=
    isSmoothOnSurface_univ_continuous F.smooth
  have hF_aesm : AEStronglyMeasurable F.toFun μK :=
    hF_cont.aestronglyMeasurable
  let KF : Set X := tsupport F.toFun
  have hKF_compact : IsCompact KF := by
    simpa [HasCompactSupportOnSurface, HasCompactSupport, KF, tsupport,
      Function.support] using F.compact_support
  rcases hKF_compact.exists_bound_of_continuousOn hF_cont.continuousOn with
    ⟨B0, hB0⟩
  let B : ℝ := max B0 0
  have hB_bound : ∀ x : X, ‖F.toFun x‖ ≤ B := by
    intro x
    by_cases hx : x ∈ KF
    · exact (hB0 x hx).trans (le_max_left B0 0)
    · have hx_not_tsupport : x ∉ tsupport F.toFun := by
        simpa [KF] using hx
      have hx_zero : F.toFun x = 0 :=
        image_eq_zero_of_notMem_tsupport hx_not_tsupport
      simp [hx_zero, B]
  have hF_mem : MemLp F.toFun (ENNReal.ofReal (2 : ℝ)) μK := by
    exact MemLp.of_bound (p := ENNReal.ofReal (2 : ℝ)) hF_aesm B
      (Filter.Eventually.of_forall hB_bound)
  have hprod_support : tsupport (fun x ↦ source x * F.toFun x) ⊆ K := by
    simpa [K] using
      (tsupport_mul_subset_left (f := source) (g := fun x ↦ F.toFun x))
  have hlocalize :
      ∫ x, source x * F.toFun x ∂g.volume =
        ∫ x, source x * F.toFun x ∂μK := by
    rw [integral_eq_setIntegral_of_tsupport_subset (μ := g.volume)
      (s := K) hprod_support]
  have hnorm :
      |∫ x, source x * F.toFun x ∂μK| ≤
        ∫ x, ‖source x * F.toFun x‖ ∂μK := by
    simpa [Real.norm_eq_abs] using
      (norm_integral_le_integral_norm (μ := μK)
        (f := fun x ↦ source x * F.toFun x))
  have hnorm_eq :
      (∫ x, ‖source x * F.toFun x‖ ∂μK) =
        ∫ x, ‖source x‖ * ‖F.toFun x‖ ∂μK := by
    simp [norm_mul]
  have hholder :
      ∫ x, ‖source x‖ * ‖F.toFun x‖ ∂μK ≤
        (∫ x, ‖source x‖ ^ (2 : ℝ) ∂μK) ^ (1 / (2 : ℝ)) *
          (∫ x, ‖F.toFun x‖ ^ (2 : ℝ) ∂μK) ^ (1 / (2 : ℝ)) := by
    simpa using
      (integral_mul_norm_le_Lp_mul_Lq (μ := μK)
        (f := source) (g := F.toFun)
        Real.HolderConjugate.two_two hsource_mem hF_mem)
  have hF_norm_sq :
      (∫ x, ‖F.toFun x‖ ^ (2 : ℝ) ∂μK) =
        ∫ x in K, ‖F.toFun x‖ ^ (2 : ℕ) ∂g.volume := by
    simp [μK]
  have hholder_sqrt :
      ∫ x, ‖source x‖ * ‖F.toFun x‖ ∂μK ≤
        A * Real.sqrt
          (∫ x in K, ‖F.toFun x‖ ^ (2 : ℕ) ∂g.volume) := by
    calc
      ∫ x, ‖source x‖ * ‖F.toFun x‖ ∂μK ≤
          (∫ x, ‖source x‖ ^ (2 : ℝ) ∂μK) ^ (1 / (2 : ℝ)) *
            (∫ x, ‖F.toFun x‖ ^ (2 : ℝ) ∂μK) ^ (1 / (2 : ℝ)) := hholder
      _ = A * Real.sqrt
            (∫ x in K, ‖F.toFun x‖ ^ (2 : ℕ) ∂g.volume) := by
          rw [← Real.sqrt_eq_rpow, hF_norm_sq, ← Real.sqrt_eq_rpow]
  calc
    |∫ x, source x * F.toFun x ∂g.volume|
        = |∫ x, source x * F.toFun x ∂μK| := by rw [hlocalize]
    _ ≤ ∫ x, ‖source x * F.toFun x‖ ∂μK := hnorm
    _ = ∫ x, ‖source x‖ * ‖F.toFun x‖ ∂μK := hnorm_eq
    _ ≤ A * Real.sqrt
          (∫ x in K, ‖F.toFun x‖ ^ (2 : ℕ) ∂g.volume) := hholder_sqrt
    _ =
        A * Real.sqrt
          (∫ x in closure {x : X | source x ≠ 0},
            ‖F.toFun x‖ ^ (2 : ℕ) ∂g.volume) := by
      simp [K, tsupport, Function.support]

/--
%%handwave
name:
  Compact source pairing with a smooth test is controlled by pure energy
statement:
  Under pure Dirichlet capacity at infinity, a smooth compactly supported
  source pairs with a compactly supported smooth function by at most a
  constant times the square root of the function's pure Dirichlet energy.
proof:
  The local \(L^2\) source estimate bounds the pairing by the local
  \(L^2\)-norm on the source support. Pure capacity controls that local norm
  by the pure Dirichlet energy.
-/
theorem compactly_supported_smooth_source_abs_pairing_smooth_le_const_mul_sqrt_dirichlet_of_pure_capacity
    {X : Type} [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    [BorelSpace X]
    {g : BackgroundSurfaceMetricOnSurface X} {source : X → ℝ}
    (hsource_compact : HasCompactSupportOnSurface source)
    (hsource_smooth : IsSmoothOnSurface (Set.univ : Set X) source)
    (hcap : HasPureDirichletCapacityAtInfinity g) :
    ∃ C : ℝ, 0 ≤ C ∧
      ∀ F : SmoothCompactlySupportedGlobalSurfaceFunction X,
        |∫ x, source x * F.toFun x ∂g.volume| ≤
          C * Real.sqrt
            (∫ x, g.gradientInner x (F.gradient x) (F.gradient x)
              ∂g.volume) := by
  classical
  let K : Set X := closure {x : X | source x ≠ 0}
  have hK_compact : IsCompact K := by
    simpa [HasCompactSupportOnSurface, K] using hsource_compact
  rcases
    compactly_supported_smooth_source_abs_pairing_smooth_le_const_mul_sqrt_localL2
      (g := g) hsource_compact hsource_smooth with
    ⟨A, hA_nonneg, hA⟩
  rcases hcap K hK_compact with ⟨P, hP_nonneg, hP⟩
  refine ⟨A * Real.sqrt P, mul_nonneg hA_nonneg (Real.sqrt_nonneg P), ?_⟩
  intro F
  have hlocal_le :
      ∫ x in K, ‖F.toFun x‖ ^ (2 : ℕ) ∂g.volume ≤
        P * ∫ x, g.gradientInner x (F.gradient x) (F.gradient x)
          ∂g.volume :=
    hP F
  have hsqrt_le :
      Real.sqrt (∫ x in K, ‖F.toFun x‖ ^ (2 : ℕ) ∂g.volume) ≤
        Real.sqrt
          (P * ∫ x, g.gradientInner x (F.gradient x) (F.gradient x)
            ∂g.volume) :=
    Real.sqrt_le_sqrt hlocal_le
  calc
    |∫ x, source x * F.toFun x ∂g.volume| ≤
        A * Real.sqrt
          (∫ x in K, ‖F.toFun x‖ ^ (2 : ℕ) ∂g.volume) := by
        simpa [K] using hA F
    _ ≤ A * Real.sqrt
          (P * ∫ x, g.gradientInner x (F.gradient x) (F.gradient x)
            ∂g.volume) :=
        mul_le_mul_of_nonneg_left hsqrt_le hA_nonneg
    _ = (A * Real.sqrt P) *
          Real.sqrt
            (∫ x, g.gradientInner x (F.gradient x) (F.gradient x)
              ∂g.volume) := by
        rw [Real.sqrt_mul hP_nonneg]
        ring

/--
%%handwave
name:
  Zero pure energy kills the compact source pairing
statement:
  Under pure Dirichlet capacity at infinity, a compactly supported smooth
  function with zero pure Dirichlet energy has zero pairing with every smooth
  compactly supported source.
proof:
  The pure-capacity source estimate bounds the absolute value of the pairing
  by a constant times the square root of the zero Dirichlet energy.
-/
theorem compactly_supported_smooth_source_pairing_eq_zero_of_pure_dirichlet_eq_zero
    {X : Type} [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    [BorelSpace X]
    {g : BackgroundSurfaceMetricOnSurface X} {source : X → ℝ}
    (hsource_compact : HasCompactSupportOnSurface source)
    (hsource_smooth : IsSmoothOnSurface (Set.univ : Set X) source)
    (hcap : HasPureDirichletCapacityAtInfinity g)
    (F : SmoothCompactlySupportedGlobalSurfaceFunction X)
    (hD :
      ∫ x, g.gradientInner x (F.gradient x) (F.gradient x) ∂g.volume = 0) :
    ∫ x, source x * F.toFun x ∂g.volume = 0 := by
  rcases
    compactly_supported_smooth_source_abs_pairing_smooth_le_const_mul_sqrt_dirichlet_of_pure_capacity
      (g := g) hsource_compact hsource_smooth hcap with
    ⟨C, _hC_nonneg, hC⟩
  have hle_zero :
      |∫ x, source x * F.toFun x ∂g.volume| ≤ 0 := by
    simpa [hD] using hC F
  have habs_zero : |∫ x, source x * F.toFun x ∂g.volume| = 0 :=
    le_antisymm hle_zero (abs_nonneg _)
  exact abs_eq_zero.mp habs_zero

/--
%%handwave
name:
  Zero pure Dirichlet energy gives zero compact local \(L^2\) mass
statement:
  Under pure Dirichlet capacity at infinity, a compactly supported smooth
  function with zero pure Dirichlet energy has zero \(L^2\)-mass on every
  compact set.
proof:
  Apply the compact local \(L^2\) estimate to the function.  The right-hand
  side is zero, while the local \(L^2\)-mass is nonnegative.
-/
theorem smoothCompactlySupported_localL2_eq_zero_of_pure_dirichlet_eq_zero
    {X : Type} [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X]
    {g : BackgroundSurfaceMetricOnSurface X}
    (hcap : HasPureDirichletCapacityAtInfinity g)
    {K : Set X} (hK : IsCompact K)
    (F : SmoothCompactlySupportedGlobalSurfaceFunction X)
    (hD :
      ∫ x, g.gradientInner x (F.gradient x) (F.gradient x) ∂g.volume = 0) :
    ∫ x in K, ‖F.toFun x‖ ^ (2 : ℕ) ∂g.volume = 0 := by
  rcases hcap K hK with ⟨P, _hP_nonneg, hP⟩
  have hle_zero :
      ∫ x in K, ‖F.toFun x‖ ^ (2 : ℕ) ∂g.volume ≤ 0 := by
    simpa [hD] using hP F
  have hnonneg :
      0 ≤ ∫ x in K, ‖F.toFun x‖ ^ (2 : ℕ) ∂g.volume :=
    integral_nonneg (fun x ↦ sq_nonneg ‖F.toFun x‖)
  exact le_antisymm hle_zero hnonneg

/--
%%handwave
name:
  Pure capacity controls differences of smooth core primitives
statement:
  On each compact set, pure capacity bounds the local \(L^2\) distance
  between the chosen smooth primitives of two smooth Dirichlet-core elements
  by the pure Dirichlet distance between those core elements.
proof:
  The difference of the two chosen primitives is a compactly supported smooth
  primitive for the difference of the two core differentials.  Apply pure
  capacity to this smooth difference and identify its Dirichlet energy with
  the squared norm of the core difference.
-/
theorem greenSobolevH10SmoothCompactSupportCorePrimitive_localL2_sub_le
    {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
    [SecondCountableTopology (SurfaceDifferentialTotalSpace X ℝ)]
    [TopologicalSpace.PseudoMetrizableSpace (SurfaceDifferentialTotalSpace X ℝ)]
    {g : BackgroundSurfaceMetricOnSurface X}
    (hcap : HasPureDirichletCapacityAtInfinity g)
    {K : Set X} (hK : IsCompact K) :
    ∃ P : ℝ, 0 ≤ P ∧
      ∀ u v : (greenSobolevH10SmoothCompactSupportCore g).Core,
        ∫ x in K,
            ‖(greenSobolevH10SmoothCompactSupportCorePrimitive u).toFun x -
              (greenSobolevH10SmoothCompactSupportCorePrimitive v).toFun x‖ ^
              (2 : ℕ) ∂g.volume ≤
          P * ‖u - v‖ ^ (2 : ℕ) := by
  rcases hcap K hK with ⟨P, hP_nonneg, hP⟩
  refine ⟨P, hP_nonneg, ?_⟩
  intro u v
  let Fu := greenSobolevH10SmoothCompactSupportCorePrimitive u
  let Fv := greenSobolevH10SmoothCompactSupportCorePrimitive v
  let hFu := greenSobolevH10SmoothCompactSupportCorePrimitive_memL2 u
  let hFv := greenSobolevH10SmoothCompactSupportCorePrimitive_memL2 v
  let negFv := SmoothCompactlySupportedGlobalSurfaceFunction.smul (-1 : ℝ) Fv
  let H := SmoothCompactlySupportedGlobalSurfaceFunction.add Fu negFv
  let dFu : SquareIntegrableSurfaceDifferentialField
      (X := X) (E := ℝ) g.metric g.volume :=
    { toSection := SurfaceDifferentialField.ofCoordinateField Fu.gradient
      memL2 := hFu }
  let dFv : SquareIntegrableSurfaceDifferentialField
      (X := X) (E := ℝ) g.metric g.volume :=
    { toSection := SurfaceDifferentialField.ofCoordinateField Fv.gradient
      memL2 := hFv }
  let dNegFv : SquareIntegrableSurfaceDifferentialField
      (X := X) (E := ℝ) g.metric g.volume :=
    squareIntegrableSurfaceDifferentialFieldSmul g.metric g.volume
      (-1 : ℝ) dFv
  have hNegFv : SurfaceDifferentialFieldMemHilbertSchmidtL2 g.metric g.volume
      (SurfaceDifferentialField.ofCoordinateField negFv.gradient) := by
    change SurfaceDifferentialFieldMemHilbertSchmidtL2 g.metric g.volume
      dNegFv.toSection
    exact dNegFv.memL2
  let dH : SquareIntegrableSurfaceDifferentialField
      (X := X) (E := ℝ) g.metric g.volume :=
    squareIntegrableSurfaceDifferentialFieldAdd g.metric g.volume dFu dNegFv
  have hH : SurfaceDifferentialFieldMemHilbertSchmidtL2 g.metric g.volume
      (SurfaceDifferentialField.ofCoordinateField H.gradient) := by
    change SurfaceDifferentialFieldMemHilbertSchmidtL2 g.metric g.volume
      dH.toSection
    exact dH.memL2
  have hH_class :
      greenSmoothDifferentialClass (g := g) H hH = (u - v).1 := by
    calc
      greenSmoothDifferentialClass (g := g) H hH =
          greenSmoothDifferentialClass (g := g) Fu hFu +
            greenSmoothDifferentialClass (g := g) negFv hNegFv :=
        greenSmoothDifferentialClass_add Fu negFv hFu hNegFv hH
      _ = greenSmoothDifferentialClass (g := g) Fu hFu +
            (-1 : ℝ) • greenSmoothDifferentialClass (g := g) Fv hFv := by
        rw [greenSmoothDifferentialClass_smul (-1 : ℝ) Fv hFv hNegFv]
      _ = u.1 + (-1 : ℝ) • v.1 := by
        rw [greenSobolevH10SmoothCompactSupportCorePrimitive_class_eq u,
          greenSobolevH10SmoothCompactSupportCorePrimitive_class_eq v]
      _ = u.1 - v.1 := by
        simp [sub_eq_add_neg]
      _ = (u - v).1 := by
        rfl
  let I : ℝ :=
    ∫ x, g.gradientInner x (H.gradient x) (H.gradient x) ∂g.volume
  have hI_nonneg : 0 ≤ I := by
    dsimp [I]
    exact
      integral_nonneg fun x ↦
        BackgroundSurfaceMetricOnSurface.gradientInner_nonneg g x (H.gradient x)
  have hI_eq_normSq : I = ‖u - v‖ ^ (2 : ℕ) := by
    have hnorm :
        ‖u - v‖ = Real.sqrt I := by
      simpa [I, hH_class] using
        greenSmoothDifferentialClass_norm_eq_sqrt_dirichlet H hH
    have hs : ‖u - v‖ ^ (2 : ℕ) = I := by
      rw [hnorm, Real.sq_sqrt hI_nonneg]
    exact hs.symm
  calc
    ∫ x in K,
        ‖(greenSobolevH10SmoothCompactSupportCorePrimitive u).toFun x -
          (greenSobolevH10SmoothCompactSupportCorePrimitive v).toFun x‖ ^
          (2 : ℕ) ∂g.volume =
        ∫ x in K, ‖H.toFun x‖ ^ (2 : ℕ) ∂g.volume := by
      apply integral_congr_ae
      filter_upwards [] with x
      simp [H, negFv, Fu, Fv, SmoothCompactlySupportedGlobalSurfaceFunction.add,
        SmoothCompactlySupportedGlobalSurfaceFunction.smul, sub_eq_add_neg]
    _ ≤ P * I := by
      simpa [I] using hP H
    _ = P * ‖u - v‖ ^ (2 : ℕ) := by
      rw [hI_eq_normSq]

/--
%%handwave
name:
  Pure-Cauchy smooth primitives are locally \(L^2\)-Cauchy
statement:
  If a sequence in the smooth Dirichlet core is Cauchy for the pure
  Dirichlet norm, then its chosen smooth primitives are Cauchy in \(L^2\) on
  every compact subset.
proof:
  On the chosen compact set, apply the pure-capacity estimate to each pair of
  primitives.  Choosing the Dirichlet distance small enough makes the
  capacity constant times the squared Dirichlet distance smaller than the
  prescribed \(L^2\) tolerance.
-/
theorem greenSobolevH10SmoothCompactSupportCorePrimitive_localL2_cauchy_of_core_norm_cauchy
    {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
    [SecondCountableTopology (SurfaceDifferentialTotalSpace X ℝ)]
    [TopologicalSpace.PseudoMetrizableSpace (SurfaceDifferentialTotalSpace X ℝ)]
    {g : BackgroundSurfaceMetricOnSurface X}
    (hcap : HasPureDirichletCapacityAtInfinity g)
    (U : ℕ → (greenSobolevH10SmoothCompactSupportCore g).Core)
    (hU_cauchy :
      ∀ ε : ℝ, 0 < ε →
        ∃ N : ℕ, ∀ n m : ℕ, N ≤ n → N ≤ m →
          ‖U n - U m‖ < ε)
    {K : Set X} (hK : IsCompact K) :
    ∀ ε : ℝ, 0 < ε →
      ∃ N : ℕ, ∀ n m : ℕ, N ≤ n → N ≤ m →
        ∫ x in K,
            ‖(greenSobolevH10SmoothCompactSupportCorePrimitive (U n)).toFun x -
              (greenSobolevH10SmoothCompactSupportCorePrimitive (U m)).toFun x‖ ^
              (2 : ℕ) ∂g.volume < ε := by
  rcases
      greenSobolevH10SmoothCompactSupportCorePrimitive_localL2_sub_le
        hcap hK with
    ⟨P, hP_nonneg, hP_bound⟩
  intro ε hε
  rcases exists_pos_mul_lt hε P with ⟨α, hα_pos, hPα_lt⟩
  let δ : ℝ := Real.sqrt α
  have hδ_pos : 0 < δ := Real.sqrt_pos.2 hα_pos
  rcases hU_cauchy δ hδ_pos with ⟨N, hN⟩
  refine ⟨N, ?_⟩
  intro n m hn hm
  have hnorm_lt : ‖U n - U m‖ < δ := hN n m hn hm
  have hnorm_sq_lt : ‖U n - U m‖ ^ (2 : ℕ) < α := by
    have hs :
        ‖U n - U m‖ ^ (2 : ℕ) < δ ^ (2 : ℕ) :=
      (sq_lt_sq₀ (norm_nonneg _) (Real.sqrt_nonneg α)).mpr hnorm_lt
    simpa [δ, Real.sq_sqrt hα_pos.le] using hs
  have hmul_lt :
      P * ‖U n - U m‖ ^ (2 : ℕ) < ε := by
    by_cases hP_zero : P = 0
    · nlinarith
    · have hP_pos : 0 < P := lt_of_le_of_ne hP_nonneg (Ne.symm hP_zero)
      exact (mul_lt_mul_of_pos_left hnorm_sq_lt hP_pos).trans hPα_lt
  exact lt_of_le_of_lt (hP_bound (U n) (U m)) hmul_lt

/--
%%handwave
name:
  Completion-convergent smooth primitives are locally \(L^2\)-Cauchy
statement:
  If smooth Dirichlet-core elements converge to a pure \(H^1_0\) class in
  the completion, then their chosen smooth primitives are Cauchy in \(L^2\)
  on every compact set.
proof:
  Completion convergence gives Cauchy convergence in the pure Dirichlet
  norm.  Pure capacity converts this into compact local \(L^2\)-Cauchy
  convergence of the primitives.
-/
theorem greenSobolevH10SmoothCompactSupportCorePrimitive_localL2_cauchy_of_tendsto_completion
    {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
    [SecondCountableTopology (SurfaceDifferentialTotalSpace X ℝ)]
    [TopologicalSpace.PseudoMetrizableSpace (SurfaceDifferentialTotalSpace X ℝ)]
    {g : BackgroundSurfaceMetricOnSurface X}
    (hcap : HasPureDirichletCapacityAtInfinity g)
    (U : ℕ → (greenSobolevH10SmoothCompactSupportCore g).Core)
    (u : GreenSobolevH10SmoothCompactSupport g)
    (hU :
      Filter.Tendsto
        (fun n : ℕ ↦
          (greenSobolevH10SmoothCompactSupportCore g).toCompletion (U n))
        Filter.atTop (𝓝 u))
    {K : Set X} (hK : IsCompact K) :
    ∀ ε : ℝ, 0 < ε →
      ∃ N : ℕ, ∀ n m : ℕ, N ≤ n → N ≤ m →
        ∫ x in K,
            ‖(greenSobolevH10SmoothCompactSupportCorePrimitive (U n)).toFun x -
              (greenSobolevH10SmoothCompactSupportCorePrimitive (U m)).toFun x‖ ^
              (2 : ℕ) ∂g.volume < ε :=
  greenSobolevH10SmoothCompactSupportCorePrimitive_localL2_cauchy_of_core_norm_cauchy
    hcap U
    (greenSobolevH10SmoothCompactSupportCore_norm_cauchy_of_tendsto_completion
      U u hU)
    hK

/--
%%handwave
name:
  Pure-Cauchy smooth primitives are compact-locally Cauchy in \(L^2\)
statement:
  If smooth Dirichlet-core elements converge in the pure \(H^1_0\)
  completion, then their chosen scalar primitives form a Cauchy sequence in
  \(L^2(K)\) for every compact set \(K\).
proof:
  The pure-capacity estimate gives Cauchy convergence of the squared
  \(L^2(K)\)-distance.  Rewriting the distance between \(L^2\)-classes as the
  \(L^2\)-seminorm of the pointwise difference and taking square roots gives
  the metric Cauchy condition.
-/
theorem greenSobolevH10SmoothCompactSupportCorePrimitive_localLp_cauchy_of_tendsto_completion
    {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
    [SecondCountableTopology (SurfaceDifferentialTotalSpace X ℝ)]
    [TopologicalSpace.PseudoMetrizableSpace (SurfaceDifferentialTotalSpace X ℝ)]
    {g : BackgroundSurfaceMetricOnSurface X}
    (hcap : HasPureDirichletCapacityAtInfinity g)
    (U : ℕ → (greenSobolevH10SmoothCompactSupportCore g).Core)
    (u : GreenSobolevH10SmoothCompactSupport g)
    (hU :
      Filter.Tendsto
        (fun n : ℕ ↦
          (greenSobolevH10SmoothCompactSupportCore g).toCompletion (U n))
        Filter.atTop (𝓝 u))
    {K : Set X} (hK : IsCompact K) :
    CauchySeq
      (fun n : ℕ ↦
        (((greenSobolevH10SmoothCompactSupportCorePrimitive (U n)).memLp_restrict_compact
          (g := g) hK).toLp
            (greenSobolevH10SmoothCompactSupportCorePrimitive (U n)).toFun :
          Lp ℝ 2 (g.volume.restrict K))) := by
  refine Metric.cauchySeq_iff'.2 ?_
  intro ε hε
  have hεsq_pos : 0 < ε ^ (2 : ℕ) := sq_pos_of_pos hε
  rcases
      greenSobolevH10SmoothCompactSupportCorePrimitive_localL2_cauchy_of_tendsto_completion
        hcap U u hU hK (ε ^ (2 : ℕ)) hεsq_pos with
    ⟨N, hN⟩
  refine ⟨N, ?_⟩
  intro n hn
  let Fn := greenSobolevH10SmoothCompactSupportCorePrimitive (U n)
  let Fm := greenSobolevH10SmoothCompactSupportCorePrimitive (U N)
  let μK := g.volume.restrict K
  have hmem_n : MemLp Fn.toFun 2 μK := by
    simpa [Fn, μK] using Fn.memLp_restrict_compact (g := g) hK
  have hmem_m : MemLp Fm.toFun 2 μK := by
    simpa [Fm, μK] using Fm.memLp_restrict_compact (g := g) hK
  have hmem_sub : MemLp (fun x ↦ Fn.toFun x - Fm.toFun x) 2 μK :=
    hmem_n.sub hmem_m
  have hdist :
      dist (hmem_n.toLp Fn.toFun) (hmem_m.toLp Fm.toFun) =
        (eLpNorm (fun x ↦ Fn.toFun x - Fm.toFun x) 2 μK).toReal := by
    rw [Lp.dist_def]
    exact congrArg ENNReal.toReal
      (eLpNorm_congr_ae (hmem_n.coeFn_toLp.sub hmem_m.coeFn_toLp))
  have hnorm :
      (eLpNorm (fun x ↦ Fn.toFun x - Fm.toFun x) 2 μK).toReal =
        Real.sqrt (∫ x, ‖Fn.toFun x - Fm.toFun x‖ ^ (2 : ℕ) ∂μK) := by
    rw [MeasureTheory.toReal_eLpNorm hmem_sub.aestronglyMeasurable]
    rw [MeasureTheory.lpNorm_eq_integral_norm_rpow_toReal
      (p := (2 : ℝ≥0∞))
      (by norm_num : (2 : ℝ≥0∞) ≠ 0)
      (by norm_num : (2 : ℝ≥0∞) ≠ (⊤ : ℝ≥0∞))
      hmem_sub.aestronglyMeasurable]
    norm_num [Real.rpow_natCast, Real.sqrt_eq_rpow]
  have hInt :
      ∫ x, ‖Fn.toFun x - Fm.toFun x‖ ^ (2 : ℕ) ∂μK < ε ^ (2 : ℕ) := by
    simpa [Fn, Fm, μK] using hN n N hn le_rfl
  have hInt_nonneg :
      0 ≤ ∫ x, ‖Fn.toFun x - Fm.toFun x‖ ^ (2 : ℕ) ∂μK :=
    integral_nonneg fun x ↦ sq_nonneg ‖Fn.toFun x - Fm.toFun x‖
  calc
    dist
        ((((greenSobolevH10SmoothCompactSupportCorePrimitive (U n)).memLp_restrict_compact
          (g := g) hK).toLp
            (greenSobolevH10SmoothCompactSupportCorePrimitive (U n)).toFun :
          Lp ℝ 2 (g.volume.restrict K)))
        ((((greenSobolevH10SmoothCompactSupportCorePrimitive (U N)).memLp_restrict_compact
          (g := g) hK).toLp
            (greenSobolevH10SmoothCompactSupportCorePrimitive (U N)).toFun :
          Lp ℝ 2 (g.volume.restrict K))) =
        dist (hmem_n.toLp Fn.toFun) (hmem_m.toLp Fm.toFun) := by
          simp [Fn, Fm, μK]
    _ = Real.sqrt (∫ x, ‖Fn.toFun x - Fm.toFun x‖ ^ (2 : ℕ) ∂μK) := by
          rw [hdist, hnorm]
    _ < ε := by
          rwa [Real.sqrt_lt hInt_nonneg hε.le]

/--
%%handwave
name:
  Pure-Cauchy smooth primitives have compact-local \(L^2\) limits
statement:
  If smooth Dirichlet-core elements converge in the pure \(H^1_0\)
  completion, then on each compact set their chosen scalar primitives
  converge in \(L^2\) to an \(L^2\)-class.
proof:
  The compact-local \(L^2\)-Cauchy statement places the primitive sequence in
  the complete \(L^2(K)\) space, so it has a limit there.
-/
theorem greenSobolevH10SmoothCompactSupportCorePrimitive_exists_localLp_limit_of_tendsto_completion
    {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
    [SecondCountableTopology (SurfaceDifferentialTotalSpace X ℝ)]
    [TopologicalSpace.PseudoMetrizableSpace (SurfaceDifferentialTotalSpace X ℝ)]
    {g : BackgroundSurfaceMetricOnSurface X}
    (hcap : HasPureDirichletCapacityAtInfinity g)
    (U : ℕ → (greenSobolevH10SmoothCompactSupportCore g).Core)
    (u : GreenSobolevH10SmoothCompactSupport g)
    (hU :
      Filter.Tendsto
        (fun n : ℕ ↦
          (greenSobolevH10SmoothCompactSupportCore g).toCompletion (U n))
        Filter.atTop (𝓝 u))
    {K : Set X} (hK : IsCompact K) :
    ∃ fK : Lp ℝ 2 (g.volume.restrict K),
      Filter.Tendsto
        (fun n : ℕ ↦
          (((greenSobolevH10SmoothCompactSupportCorePrimitive (U n)).memLp_restrict_compact
            (g := g) hK).toLp
              (greenSobolevH10SmoothCompactSupportCorePrimitive (U n)).toFun :
            Lp ℝ 2 (g.volume.restrict K)))
        Filter.atTop (𝓝 fK) := by
  exact
    cauchySeq_tendsto_of_complete
      (greenSobolevH10SmoothCompactSupportCorePrimitive_localLp_cauchy_of_tendsto_completion
        hcap U u hU hK)

/--
%%handwave
name:
  Pure capacity gives a smooth-core local Cauchy approximation
statement:
  Every completed pure \(H^1_0\) class admits smooth-core approximants whose
  primitives are compact-locally \(L^2\)-Cauchy and whose differential
  classes converge to the completed differential class.
proof:
  Choose a dense smooth-core sequence converging to the completed class.
  Pure capacity turns completion convergence into compact-local \(L^2\)
  Cauchy convergence of the primitives, and continuity of the ambient
  differential-class map gives convergence of the differentials.
-/
theorem greenSobolevH10SmoothCompactSupport_exists_core_sequence_with_localL2_cauchy
    {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
    [SecondCountableTopology (SurfaceDifferentialTotalSpace X ℝ)]
    [TopologicalSpace.PseudoMetrizableSpace (SurfaceDifferentialTotalSpace X ℝ)]
    {g : BackgroundSurfaceMetricOnSurface X}
    (hcap : HasPureDirichletCapacityAtInfinity g)
    (u : GreenSobolevH10SmoothCompactSupport g) :
    ∃ U : ℕ → (greenSobolevH10SmoothCompactSupportCore g).Core,
      Filter.Tendsto
        (fun n : ℕ ↦
          (greenSobolevH10SmoothCompactSupportCore g).toCompletion (U n))
        Filter.atTop (𝓝 u) ∧
      (∀ K : Set X, IsCompact K →
        ∀ ε : ℝ, 0 < ε →
          ∃ N : ℕ, ∀ n m : ℕ, N ≤ n → N ≤ m →
            ∫ x in K,
                ‖(greenSobolevH10SmoothCompactSupportCorePrimitive (U n)).toFun x -
                  (greenSobolevH10SmoothCompactSupportCorePrimitive (U m)).toFun x‖ ^
                  (2 : ℕ) ∂g.volume < ε) ∧
      Filter.Tendsto (fun n : ℕ ↦ (U n).1) Filter.atTop
        (𝓝 (greenSobolevH10SmoothCompactSupportDifferentialClass u)) := by
  rcases greenSobolevH10SmoothCompactSupport_exists_core_sequence_tendsto u with
    ⟨U, hU⟩
  refine ⟨U, hU, ?_, ?_⟩
  · intro K hK ε hε
    exact
      greenSobolevH10SmoothCompactSupportCorePrimitive_localL2_cauchy_of_tendsto_completion
        hcap U u hU hK ε hε
  · exact
      greenSobolevH10SmoothCompactSupportCore_differentialClass_tendsto
        U u hU

/--
%%handwave
name:
  Positive pure Dirichlet capacity at infinity
statement:
  A Riemann surface has positive pure Dirichlet capacity at infinity if the
  pure Dirichlet capacity condition holds for some conformal smooth
  background metric.
proof:
  The pure Dirichlet seminorm is conformally invariant on surfaces, so a
  conformal background metric is used only as a representative for writing the
  Sobolev and integral expressions.
-/
def HasPositivePureDirichletCapacityAtInfinity
    (X : Type) [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] :
    Prop :=
  ∃ g : BackgroundSurfaceMetricOnSurface X,
    BackgroundSurfaceMetricConformalToComplexStructure g ∧
      HasPureDirichletCapacityAtInfinity g

end Uniformization

