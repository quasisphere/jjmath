/--
%%handwave
name:
  Chosen differential representative has finite Dirichlet energy
statement:
  The coordinate cotangent field of the chosen differential representative of
  a completed pure \(H^1_0\) class has integrable Dirichlet density.
proof:
  Square-integrability of the representative gives integrability of its
  intrinsic Hilbert--Schmidt square norm.  For scalar surface cotangents this
  square norm is exactly the Dirichlet density.
-/
theorem greenSobolevH10SmoothCompactSupportDifferentialRep_dirichlet_integrable
    {X : Type}
    [TopologicalSpace X] [ChartedSpace ℂ X] [MeasurableSpace X] [BorelSpace X]
    [MeasurableEq X] [IsManifold SurfaceRealModel ∞ X]
    [SecondCountableTopology (SurfaceDifferentialTotalSpace X ℝ)]
    [TopologicalSpace.PseudoMetrizableSpace (SurfaceDifferentialTotalSpace X ℝ)]
    {g : BackgroundSurfaceMetricOnSurface X}
    (u : GreenSobolevH10SmoothCompactSupport g) :
    Integrable
      (fun x ↦
        g.gradientInner x
          (SurfaceDifferentialField.toCoordinateField
            (greenSobolevH10SmoothCompactSupportDifferentialRep u).toField x)
          (SurfaceDifferentialField.toCoordinateField
            (greenSobolevH10SmoothCompactSupportDifferentialRep u).toField x))
      g.volume := by
  let du := greenSobolevH10SmoothCompactSupportDifferentialRep u
  have hnorm :
      Integrable
        (fun x ↦
          (manifoldDifferentialHilbertBundleGeometry
            (I := SurfaceRealModel) (X := X) (E := ℝ)
            g.metric.toManifoldMetric).fiberNormSq x (du.toField x))
        g.volume :=
    du.memL2.integrable_normSq
  refine hnorm.congr ?_
  filter_upwards [] with x
  simpa [du, SurfaceDifferentialField.toCoordinateField] using
    (surface_coordinate_cotangent_fiberNormSq_eq_gradientInner
      g x
      (SurfaceDifferentialField.toCoordinateField
        (greenSobolevH10SmoothCompactSupportDifferentialRep u).toField x))

