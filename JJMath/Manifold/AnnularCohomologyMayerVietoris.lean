/--
%%handwave
name:
  Degree-zero cohomology of the doubly punctured annular cylinder
statement:
  Every class \(\alpha\) on the doubly punctured cylinder has the form
  \[
    \alpha=[c]+d[s],
  \]
  where \(s\) is the locally constant function equal to \(1\) on the positive
  component and \(0\) on the negative component.
proof:
  Restrict \(\alpha\) to the two components, obtaining constants
  \(c_+\) and \(c_-\).  The class
  \([c_-]+(c_+-c_-)[s]\) has the same restriction on both components, hence
  equals \(\alpha\).
-/
theorem annularDoublePuncture_H0_eq_constant_add_smul_step
    (v : Circle)
    (alpha : DeRhamCohomology (I := AnnularCylinderModel)
      (M := annularDoublePunctureOpen v) (A := ℝ) 0) :
    ∃ c d : ℝ,
      alpha =
        deRhamConstantH0Class (I0 := AnnularCylinderModel)
            (M0 := annularDoublePunctureOpen v) c +
          d • annularOverlapStepClass v := by
  classical
  induction alpha using Submodule.Quotient.induction_on with
  | _ omega =>
      let alphaPos :=
        deRhamCohomologyRestrictionOfLE (I := AnnularCylinderModel) (A := ℝ)
          (annularPositiveComponent_le_doublePuncture v) 0
          ((DeRhamExactClosedForms (I := AnnularCylinderModel)
            (M := annularDoublePunctureOpen v) (A := ℝ) 0).mkQ omega)
      let alphaNeg :=
        deRhamCohomologyRestrictionOfLE (I := AnnularCylinderModel) (A := ℝ)
          (annularNegativeComponent_le_doublePuncture v) 0
          ((DeRhamExactClosedForms (I := AnnularCylinderModel)
            (M := annularDoublePunctureOpen v) (A := ℝ) 0).mkQ omega)
      rcases annularPositiveComponent_H0_eq_constant v alphaPos with ⟨cPos, hcPos⟩
      rcases annularNegativeComponent_H0_eq_constant v alphaNeg with ⟨cNeg, hcNeg⟩
      refine ⟨cNeg, cPos - cNeg, ?_⟩
      have hcPos' :
          (DeRhamExactClosedForms (I := AnnularCylinderModel)
            (M := annularPositiveComponent v) (A := ℝ) 0).mkQ
              (deRhamClosedFormsRestrictionOfLE
                (I := AnnularCylinderModel) (A := ℝ)
                (annularPositiveComponent_le_doublePuncture v) 0 omega) =
            (DeRhamExactClosedForms (I := AnnularCylinderModel)
              (M := annularPositiveComponent v) (A := ℝ) 0).mkQ
                (deRhamConstantZeroClosedForm (I0 := AnnularCylinderModel)
                  (M0 := annularPositiveComponent v) cPos) := by
        simpa [alphaPos, deRhamCohomologyRestrictionOfLE,
          deRhamConstantH0Class] using hcPos
      have hcNeg' :
          (DeRhamExactClosedForms (I := AnnularCylinderModel)
            (M := annularNegativeComponent v) (A := ℝ) 0).mkQ
              (deRhamClosedFormsRestrictionOfLE
                (I := AnnularCylinderModel) (A := ℝ)
                (annularNegativeComponent_le_doublePuncture v) 0 omega) =
            (DeRhamExactClosedForms (I := AnnularCylinderModel)
              (M := annularNegativeComponent v) (A := ℝ) 0).mkQ
                (deRhamConstantZeroClosedForm (I0 := AnnularCylinderModel)
                  (M0 := annularNegativeComponent v) cNeg) := by
        simpa [alphaNeg, deRhamCohomologyRestrictionOfLE,
          deRhamConstantH0Class] using hcNeg
      have hcPosClosed :=
        (deRhamH0_mkQ_eq_iff AnnularCylinderModel _ _).mp hcPos'
      have hcNegClosed :=
        (deRhamH0_mkQ_eq_iff AnnularCylinderModel _ _).mp hcNeg'
      have hforms :
          omega =
            deRhamConstantZeroClosedForm (I0 := AnnularCylinderModel)
                (M0 := annularDoublePunctureOpen v) cNeg +
              (cPos - cNeg) • annularOverlapStepClosedForm v := by
        apply Subtype.ext
        apply DifferentialForm.ext
        intro x
        ext q
        rw [show q = (fun i : Fin 0 => nomatch i) from Subsingleton.elim _ _]
        have hxcover : (x.1 : Circle × ℝ) ∈
            (annularPositiveComponent v : Set (Circle × ℝ)) ∨
          (x.1 : Circle × ℝ) ∈
            (annularNegativeComponent v : Set (Circle × ℝ)) := by
          have hx : (x.1 : Circle × ℝ) ∈
              (annularPositiveComponent v ⊔ annularNegativeComponent v :
                TopologicalSpace.Opens (Circle × ℝ)) := by
            rw [annularComponents_cover_doublePuncture v]
            exact x.property
          exact hx
        rcases hxcover with hxPos | hxNeg
        · let xPos : annularPositiveComponent v := ⟨x.1, hxPos⟩
          have hvalue := congrArg
            (fun eta : DeRhamClosedForms (I := AnnularCylinderModel)
                (M := annularPositiveComponent v) (A := ℝ) 0 =>
              eta.1.toFun xPos (fun i : Fin 0 => nomatch i)) hcPosClosed
          have harg :
              (mfderiv AnnularCylinderModel AnnularCylinderModel
                  (TopologicalSpace.Opens.inclusion
                    (annularPositiveComponent_le_doublePuncture v)) xPos ∘
                (fun i : Fin 0 => nomatch i)) =
              (fun i : Fin 0 => nomatch i) := Subsingleton.elim _ _
          have hvalue' :
              omega.1.toFun x (fun i : Fin 0 => nomatch i) = cPos := by
            simpa [xPos, deRhamClosedFormsRestrictionOfLE,
              restrictSmoothFormsOfLE, restrictSmoothFormOfLE,
              deRhamConstantZeroClosedForm, smoothRealFunctionToZeroForm,
              smoothRealConstantFunction, harg] using hvalue
          have hxStep : x ∈ annularOverlapPositiveSet v := hxPos
          simp only [deRhamConstantZeroClosedForm, annularOverlapStepClosedForm,
            smoothRealFunctionToZeroForm, smoothRealConstantFunction,
            smoothRealFunctionOfIsLocallyConstant]
          change omega.1.toFun x (fun i : Fin 0 => nomatch i) =
            cNeg + (cPos - cNeg) *
              (if x ∈ annularOverlapPositiveSet v then 1 else 0)
          rw [if_pos hxStep, hvalue']
          ring
        · let xNeg : annularNegativeComponent v := ⟨x.1, hxNeg⟩
          have hvalue := congrArg
            (fun eta : DeRhamClosedForms (I := AnnularCylinderModel)
                (M := annularNegativeComponent v) (A := ℝ) 0 =>
              eta.1.toFun xNeg (fun i : Fin 0 => nomatch i)) hcNegClosed
          have harg :
              (mfderiv AnnularCylinderModel AnnularCylinderModel
                  (TopologicalSpace.Opens.inclusion
                    (annularNegativeComponent_le_doublePuncture v)) xNeg ∘
                (fun i : Fin 0 => nomatch i)) =
              (fun i : Fin 0 => nomatch i) := Subsingleton.elim _ _
          have hvalue' :
              omega.1.toFun x (fun i : Fin 0 => nomatch i) = cNeg := by
            simpa [xNeg, deRhamClosedFormsRestrictionOfLE,
              restrictSmoothFormsOfLE, restrictSmoothFormOfLE,
              deRhamConstantZeroClosedForm, smoothRealFunctionToZeroForm,
              smoothRealConstantFunction, harg] using hvalue
          have hxStep : x ∉ annularOverlapPositiveSet v := by
            intro hxPos
            have hmem : (x.1 : Circle × ℝ) ∈
                (annularPositiveComponent v ⊓ annularNegativeComponent v :
                  TopologicalSpace.Opens (Circle × ℝ)) := ⟨hxPos, hxNeg⟩
            rw [annularComponents_disjoint v] at hmem
            exact hmem
          simp only [deRhamConstantZeroClosedForm, annularOverlapStepClosedForm,
            smoothRealFunctionToZeroForm, smoothRealConstantFunction,
            smoothRealFunctionOfIsLocallyConstant]
          change omega.1.toFun x (fun i : Fin 0 => nomatch i) =
            cNeg + (cPos - cNeg) *
              (if x ∈ annularOverlapPositiveSet v then 1 else 0)
          rw [if_neg hxStep, hvalue']
          ring
      have hquot := congrArg
        (DeRhamExactClosedForms (I := AnnularCylinderModel)
          (M := annularDoublePunctureOpen v) (A := ℝ) 0).mkQ hforms
      simpa only [deRhamConstantH0Class, annularOverlapStepClass,
        map_add, map_smul] using hquot

/--
%%handwave
name:
  Cover of the annular cylinder by two punctures
statement:
  The two open cylinders obtained by removing \(v\) and its distinguished
  opposite \(v^\ast\) cover \(S^1\times\mathbb R\).
proof:
  Since \(v\ne v^\ast\), a circle point cannot equal both punctures.
-/
theorem annularPunctures_cover (v : Circle) :
    annularPunctureOpen v ⊔ annularPunctureOpen (annularOpposite v) = ⊤ := by
  ext p
  constructor
  · intro
    trivial
  · intro
    change p ∈ annularPunctureOpen v ∨
      p ∈ annularPunctureOpen (annularOpposite v)
    by_cases hp : p.1 = v
    · right
      apply (mem_annularPunctureOpen_iff (annularOpposite v) p).mpr
      rw [hp]
      exact (annularOpposite_ne v).symm
    · left
      exact (mem_annularPunctureOpen_iff v p).mpr hp

noncomputable def annularStepConnectingClass (v : Circle) :
    DeRhamCohomology (I := AnnularCylinderModel)
      (M := Circle × ℝ) (A := ℝ) 1 :=
  deRhamMayerVietorisConnectingOfPartitionOfUnity (A := ℝ)
    AnnularCylinderModel (annularPunctureOpen v)
      (annularPunctureOpen (annularOpposite v)) (annularPunctures_cover v) 0
      (annularOverlapStepClass v)

