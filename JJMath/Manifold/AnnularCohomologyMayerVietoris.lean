theorem annularCylinder_deRhamH1_eq_smul_stepConnecting
    (v : Circle)
    (alpha : DeRhamCohomology (I := AnnularCylinderModel)
      (M := Circle × ℝ) (A := ℝ) 1) :
    ∃ d : ℝ, alpha = d • annularStepConnectingClass v := by
  let U := annularPunctureOpen v
  let V := annularPunctureOpen (annularOpposite v)
  let hcover : U ⊔ V = ⊤ := annularPunctures_cover v
  letI : Subsingleton
      (DeRhamCohomology (I := AnnularCylinderModel) (M := U) (A := ℝ) 1) := by
    simpa [U] using annularPuncture_deRhamH1_subsingleton v
  letI : Subsingleton
      (DeRhamCohomology (I := AnnularCylinderModel) (M := V) (A := ℝ) 1) := by
    simpa [V] using annularPuncture_deRhamH1_subsingleton (annularOpposite v)
  let connecting :=
    deRhamMayerVietorisConnectingOfPartitionOfUnity (A := ℝ)
      AnnularCylinderModel U V hcover 0
  have hrestriction :
      deRhamMayerVietorisRestriction (I := AnnularCylinderModel) (A := ℝ)
          U V 1 alpha = 0 := by
    apply Prod.ext
    · exact Subsingleton.elim _ _
    · exact Subsingleton.elim _ _
  have hexact :=
    deRham_mayerVietoris_exact_connecting_restriction_of_partitionOfUnity
      (A := ℝ) AnnularCylinderModel U V hcover 0
  have hrange : alpha ∈ Set.range connecting := (hexact alpha).mp hrestriction
  rcases hrange with ⟨eta, heta⟩
  change DeRhamCohomology (I := AnnularCylinderModel)
    (M := annularDoublePunctureOpen v) (A := ℝ) 0 at eta
  rcases annularDoublePuncture_H0_eq_constant_add_smul_step v eta with
    ⟨c, d, hdecomp⟩
  have hconstant_range :
      deRhamConstantH0Class (I0 := AnnularCylinderModel)
          (M0 := annularDoublePunctureOpen v) c ∈
        Set.range
          (deRhamMayerVietorisDifference (I := AnnularCylinderModel) (A := ℝ)
            U V 0) := by
    refine ⟨
      (deRhamConstantH0Class (I0 := AnnularCylinderModel) (M0 := U) c,
        0), ?_⟩
    change
      deRhamCohomologyRestrictionOfLE (I := AnnularCylinderModel) (A := ℝ)
          (W := annularDoublePunctureOpen v) (V := U) inf_le_left 0
          (deRhamConstantH0Class (I0 := AnnularCylinderModel) (M0 := U) c) -
        deRhamCohomologyRestrictionOfLE (I := AnnularCylinderModel) (A := ℝ)
          (W := annularDoublePunctureOpen v) (V := V) inf_le_right 0 0 =
        deRhamConstantH0Class (I0 := AnnularCylinderModel)
          (M0 := annularDoublePunctureOpen v) c
    rw [deRhamCohomologyRestrictionOfLE_constant]
    simp
  have hconstant_zero :
      connecting
          (deRhamConstantH0Class (I0 := AnnularCylinderModel)
            (M0 := annularDoublePunctureOpen v) c) = 0 := by
    have hexact0 :=
      deRham_mayerVietoris_exact_difference_connecting_of_partitionOfUnity
        (A := ℝ) AnnularCylinderModel U V hcover 0
    exact (hexact0 _).mpr hconstant_range
  refine ⟨d, ?_⟩
  calc
    alpha = connecting eta := heta.symm
    _ = connecting
        (deRhamConstantH0Class (I0 := AnnularCylinderModel)
            (M0 := annularDoublePunctureOpen v) c +
          d • annularOverlapStepClass v) := congrArg connecting hdecomp
    _ = connecting
          (deRhamConstantH0Class (I0 := AnnularCylinderModel)
            (M0 := annularDoublePunctureOpen v) c) +
        connecting (d • annularOverlapStepClass v) :=
      deRhamMayerVietorisConnectingOfPartitionOfUnity_add
        AnnularCylinderModel U V hcover 0 _ _
    _ = 0 + d • connecting (annularOverlapStepClass v) := by
      have hsmul :=
        deRhamMayerVietorisConnectingOfPartitionOfUnity_smul
          AnnularCylinderModel U V hcover 0 d (annularOverlapStepClass v)
      change connecting (d • annularOverlapStepClass v) =
        d • connecting (annularOverlapStepClass v) at hsmul
      rw [hconstant_zero, hsmul]
    _ = d • annularStepConnectingClass v := by
      simp [annularStepConnectingClass, U, V, connecting]

