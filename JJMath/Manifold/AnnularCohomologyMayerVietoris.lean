theorem annularPuncture_H0_eq_constant (v : Circle)
    (alpha : DeRhamCohomology (I := AnnularCylinderModel)
      (M := annularPunctureOpen v) (A := ℝ) 0) :
    ∃ c : ℝ, alpha = deRhamConstantH0Class
