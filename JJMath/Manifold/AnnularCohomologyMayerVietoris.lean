    ⟨V, hconvex, hne, ⟨phi⟩⟩
  exact deRhamH0_eq_constant_of_diffeomorphic_convex
    AnnularCylinderModel V hconvex ⟨hne.choose, hne.choose_spec⟩ phi alpha

