/--
%%handwave
name:
  Injectivity of one restriction in a two-open cover
statement:
  Let \(M=U\cup V\).  If
  \(H_{\mathrm{dR}}^1(M;\mathbb R)=0\) and
  \(H_{\mathrm{dR}}^1(V;\mathbb R)=0\), then restriction
  \[
    H_{\mathrm{dR}}^1(U;\mathbb R)\longrightarrow
    H_{\mathrm{dR}}^1(U\cap V;\mathbb R)
  \]
  is injective.
proof:
  If two classes have the same restriction, their difference paired with zero
  on \(V\) lies in the kernel of the Mayer--Vietoris difference map.
  Exactness lifts this pair from an ambient class, which is zero; hence the
  difference on \(U\) is zero.
-/
theorem deRhamH1_left_restriction_injective_of_ambient_right_subsingleton
    {E H M : Type*}
    [NormedAddCommGroup E] [NormedSpace ℝ E] [FiniteDimensional ℝ E]
    [TopologicalSpace H] [TopologicalSpace M] [ChartedSpace H M]
    (I : ModelWithCorners ℝ E H) [IsManifold I ∞ M]
    [T2Space M] [SigmaCompactSpace M]
    [Subsingleton
      (DeRhamCohomology (I := I) (M := M) (A := ℝ) 1)]
    (U V : TopologicalSpace.Opens M) (hcover : U ⊔ V = ⊤)
    [Subsingleton
      (DeRhamCohomology (I := I) (M := V) (A := ℝ) 1)] :
    Function.Injective
      (deRhamCohomologyRestrictionOfLE (I := I) (A := ℝ)
        (W := (U ⊓ V : TopologicalSpace.Opens M)) (V := U)
        inf_le_left 1) := by
  intro alpha beta hab
  let rho := deRhamCohomologyRestrictionOfLE
    (I := I) (A := ℝ)
    (W := (U ⊓ V : TopologicalSpace.Opens M)) (V := U)
    inf_le_left 1
  let sigma := deRhamCohomologyRestrictionOfLE
    (I := I) (A := ℝ)
    (W := (U ⊓ V : TopologicalSpace.Opens M)) (V := V)
    inf_le_right 1
  let delta := alpha - beta
  have hrho_delta : rho delta = 0 := by
    change (deRhamCohomologyRestrictionOfLE (I := I) (A := ℝ)
      (W := (U ⊓ V : TopologicalSpace.Opens M)) (V := U)
      inf_le_left 1) (alpha - beta) = 0
    rw [(deRhamCohomologyRestrictionOfLE (I := I) (A := ℝ)
      (W := (U ⊓ V : TopologicalSpace.Opens M)) (V := U)
      inf_le_left 1).map_sub, hab, sub_self]
  let zeroV : DeRhamCohomology (I := I) (M := V) (A := ℝ) 1 := 0
  have hdiff :
      deRhamMayerVietorisDifference (I := I) (A := ℝ) U V 1
          (delta, zeroV) = 0 := by
    change rho delta - sigma zeroV = 0
    rw [hrho_delta]
    have hsigma_zero : sigma zeroV = 0 := by
      exact sigma.map_zero
    rw [hsigma_zero, sub_zero]
  rcases deRham_mayerVietoris_longExact (A := ℝ) I U V hcover with ⟨LES⟩
  rcases (LES.exact_restriction_difference 1 (delta, zeroV)).mp hdiff with
    ⟨ambient, hambient⟩
  have hambient_zero : ambient = 0 := Subsingleton.elim _ _
  have hpair : (delta, zeroV) =
      (0 : DeRhamCohomology (I := I) (M := U) (A := ℝ) 1 ×
        DeRhamCohomology (I := I) (M := V) (A := ℝ) 1) := by
    calc
      (delta, zeroV) = deRhamMayerVietorisRestriction
          (I := I) (A := ℝ) U V 1 ambient := hambient.symm
      _ = deRhamMayerVietorisRestriction
          (I := I) (A := ℝ) U V 1 0 := congrArg _ hambient_zero
      _ = 0 := by
        apply Prod.ext
        · exact (deRhamCohomologyRestrictionToOpen
            (I := I) (M := M) (A := ℝ) U 1).map_zero
        · exact (deRhamCohomologyRestrictionToOpen
            (I := I) (M := M) (A := ℝ) V 1).map_zero
  have hdelta : delta = 0 := congrArg Prod.fst hpair
  exact sub_eq_zero.mp hdelta


set_option synthInstance.maxHeartbeats 100000 in
/--
%%handwave
name:
  Mayer--Vietoris vanishing across an annular overlap
statement:
  Let \(M=U\cup V\), suppose \(U\cap V\) is a smooth annulus and
  \(H_{\mathrm{dR}}^1(M;\mathbb R)=0\).  If
  \(H_{\mathrm{dR}}^1(U;\mathbb R)\ne0\), then
  \(H_{\mathrm{dR}}^1(V;\mathbb R)=0\).
proof:
  Choose a nonzero class on \(U\).  Exactness and ambient vanishing show that
  its restriction to \(U\cap V\) is nonzero.  Since any nonzero annular class
  generates the overlap cohomology, the left restriction is surjective.
  The Mayer--Vietoris injectivity criterion then forces the right first
  cohomology to vanish.
-/
theorem deRhamH1_subsingleton_of_mayerVietoris_annular_and_left_nontrivial
    {E H M : Type*}
    [NormedAddCommGroup E] [NormedSpace ℝ E] [FiniteDimensional ℝ E]
    [TopologicalSpace H] [TopologicalSpace M] [ChartedSpace H M]
    (I : ModelWithCorners ℝ E H) [IsManifold I ∞ M]
    [T2Space M] [SigmaCompactSpace M]
    [Subsingleton
      (DeRhamCohomology (I := I) (M := M) (A := ℝ) 1)]
    (U V : TopologicalSpace.Opens M) (hcover : U ⊔ V = ⊤)
    (phi : (U ⊓ V : TopologicalSpace.Opens M) ≃ₘ⟮I,
      AnnularCylinderModel⟯ Circle × ℝ)
    (v : Circle)
    (hleft : ¬ Subsingleton
      (DeRhamCohomology (I := I) (M := U) (A := ℝ) 1)) :
    Subsingleton
      (DeRhamCohomology (I := I) (M := V) (A := ℝ) 1) := by
  letI : Nontrivial
      (DeRhamCohomology (I := I) (M := U) (A := ℝ) 1) :=
    not_subsingleton_iff_nontrivial.mp hleft
  rcases exists_ne
      (0 : DeRhamCohomology (I := I) (M := U) (A := ℝ) 1) with
    ⟨tau, htau⟩
  let rho := deRhamCohomologyRestrictionOfLE
    (I := I) (A := ℝ)
    (W := (U ⊓ V : TopologicalSpace.Opens M)) (V := U)
    inf_le_left 1
  have hrho_tau : rho tau ≠ 0 := by
    intro hrho_tau_zero
    rcases deRham_mayerVietoris_longExact (A := ℝ) I U V hcover with ⟨LES⟩
    let zeroV : DeRhamCohomology (I := I) (M := V) (A := ℝ) 1 := 0
    have hdiff :
        deRhamMayerVietorisDifference (I := I) (A := ℝ) U V 1
            (tau, zeroV) = 0 := by
      change rho tau -
        deRhamCohomologyRestrictionOfLE (I := I) (A := ℝ)
          (W := (U ⊓ V : TopologicalSpace.Opens M)) (V := V)
          inf_le_right 1 0 = 0
      rw [hrho_tau_zero]
      rw [(deRhamCohomologyRestrictionOfLE (I := I) (A := ℝ)
        (W := (U ⊓ V : TopologicalSpace.Opens M)) (V := V)
        inf_le_right 1).map_zero]
      exact sub_self
        (0 : DeRhamCohomology (I := I)
          (M := (U ⊓ V : TopologicalSpace.Opens M)) (A := ℝ) 1)
    rcases (LES.exact_restriction_difference 1 (tau, zeroV)).mp hdiff with
      ⟨ambient, hambient⟩
    have hambient_zero : ambient = 0 := Subsingleton.elim _ _
    have hpair : (tau, zeroV) =
        (0 : DeRhamCohomology (I := I) (M := U) (A := ℝ) 1 ×
          DeRhamCohomology (I := I) (M := V) (A := ℝ) 1) := by
      calc
        (tau, 0) = deRhamMayerVietorisRestriction
            (I := I) (A := ℝ) U V 1 ambient := hambient.symm
        _ = deRhamMayerVietorisRestriction
            (I := I) (A := ℝ) U V 1 0 := congrArg _ hambient_zero
        _ = 0 := by
          apply Prod.ext
          · exact (deRhamCohomologyRestrictionToOpen
              (I := I) (M := M) (A := ℝ) U 1).map_zero
          · exact (deRhamCohomologyRestrictionToOpen
              (I := I) (M := M) (A := ℝ) V 1).map_zero
    exact htau (congrArg Prod.fst hpair)
  apply deRhamH1_subsingleton_of_mayerVietoris_left_restriction_surjective
    (A := ℝ) I U V hcover
  intro alpha
  rcases deRhamH1_eq_smul_of_diffeomorphic_annularCylinder
      I phi v (rho tau) hrho_tau alpha with ⟨c, hc⟩
  refine ⟨c • tau, ?_⟩
  rw [map_smul, ← hc]

end
