theorem annularCylinder_deRhamH1_eq_smul_of_ne_zero
    (v : Circle)
    (tau : DeRhamCohomology (I := AnnularCylinderModel)
      (M := Circle × ℝ) (A := ℝ) 1)
    (htau : tau ≠ 0)
    (alpha : DeRhamCohomology (I := AnnularCylinderModel)
      (M := Circle × ℝ) (A := ℝ) 1) :
    ∃ c : ℝ, alpha = c • tau := by
  rcases annularCylinder_deRhamH1_eq_smul_stepConnecting v tau with
    ⟨d, hd⟩
  have hd_ne : d ≠ 0 := by
    intro hd_zero
    apply htau
    simpa [hd_zero] using hd
  rcases annularCylinder_deRhamH1_eq_smul_stepConnecting v alpha with
    ⟨e, he⟩
  refine ⟨e / d, ?_⟩
  rw [he, hd]
  rw [smul_smul]
  field_simp

/-- First de Rham cohomology of any smooth annulus is generated by each of
its nonzero classes. -/
theorem deRhamH1_eq_smul_of_diffeomorphic_annularCylinder
    {E H M : Type*}
    [NormedAddCommGroup E] [NormedSpace ℝ E]
    [TopologicalSpace H] [TopologicalSpace M] [ChartedSpace H M]
    (I : ModelWithCorners ℝ E H) [IsManifold I ∞ M]
    (phi : M ≃ₘ⟮I, AnnularCylinderModel⟯ Circle × ℝ)
    (v : Circle)
    (tau : DeRhamCohomology (I := I) (M := M) (A := ℝ) 1)
    (htau : tau ≠ 0)
    (alpha : DeRhamCohomology (I := I) (M := M) (A := ℝ) 1) :
    ∃ c : ℝ, alpha = c • tau := by
  let tauCylinder := deRhamCohomologyPullbackDiffeomorph
    AnnularCylinderModel I phi.symm 1 tau
  have htauCylinder : tauCylinder ≠ 0 := by
    intro htauCylinder_zero
    apply htau
    calc
      tau = deRhamCohomologyPullbackDiffeomorph
          I AnnularCylinderModel phi 1 tauCylinder :=
        (deRhamCohomologyPullbackDiffeomorph_comp_symm
          I AnnularCylinderModel phi 1 tau).symm
      _ = 0 := by
        rw [htauCylinder_zero]
        exact (deRhamCohomologyPullbackDiffeomorph
          I AnnularCylinderModel phi 1).map_zero
  let alphaCylinder := deRhamCohomologyPullbackDiffeomorph
    AnnularCylinderModel I phi.symm 1 alpha
  rcases annularCylinder_deRhamH1_eq_smul_of_ne_zero
      v tauCylinder htauCylinder alphaCylinder with ⟨c, hc⟩
  refine ⟨c, ?_⟩
  calc
    alpha = deRhamCohomologyPullbackDiffeomorph
        I AnnularCylinderModel phi 1 alphaCylinder :=
      (deRhamCohomologyPullbackDiffeomorph_comp_symm
        I AnnularCylinderModel phi 1 alpha).symm
    _ = deRhamCohomologyPullbackDiffeomorph
        I AnnularCylinderModel phi 1 (c • tauCylinder) := congrArg _ hc
    _ = c • deRhamCohomologyPullbackDiffeomorph
        I AnnularCylinderModel phi 1 tauCylinder := by rw [map_smul]
    _ = c • tau := by
      rw [deRhamCohomologyPullbackDiffeomorph_comp_symm]

