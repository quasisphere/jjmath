import JJMath.Manifold.AnnularCohomology
import JJMath.Manifold.DeRhamMayerVietorisLinear

/-!
# The first de Rham cohomology of an annular cylinder

Two punctured-cylinder charts cover the cylinder. Their overlap has two
components, so its degree-zero cohomology is generated by a constant and a
locally constant step function. Mayer--Vietoris then shows that first de Rham
cohomology of the cylinder is generated by the connecting class of that step
function.
-/

open Set
open scoped Manifold ContDiff Topology

namespace JJMath.Manifold

noncomputable section

attribute [local instance] finrank_real_complex_fact'

theorem deRhamCohomologyPullbackDiffeomorph_constant
    {E₁ H₁ M₁ E₂ H₂ M₂ : Type*}
    [NormedAddCommGroup E₁] [NormedSpace ℝ E₁]
    [NormedAddCommGroup E₂] [NormedSpace ℝ E₂]
    [TopologicalSpace H₁] [TopologicalSpace M₁] [ChartedSpace H₁ M₁]
    [TopologicalSpace H₂] [TopologicalSpace M₂] [ChartedSpace H₂ M₂]
    (I₁ : ModelWithCorners ℝ E₁ H₁) (I₂ : ModelWithCorners ℝ E₂ H₂)
    [IsManifold I₁ ∞ M₁] [IsManifold I₂ ∞ M₂]
    (phi : M₁ ≃ₘ⟮I₁, I₂⟯ M₂) (c : ℝ) :
    deRhamCohomologyPullbackDiffeomorph I₁ I₂ phi 0
        (deRhamConstantH0Class (I0 := I₂) (M0 := M₂) c) =
      deRhamConstantH0Class (I0 := I₁) (M0 := M₁) c := by
  simp only [deRhamConstantH0Class, deRhamCohomologyPullbackDiffeomorph]
  apply congrArg
    (DeRhamExactClosedForms (I := I₁) (M := M₁) (A := ℝ) 0).mkQ
  apply Subtype.ext
  apply DifferentialForm.ext
  intro x
  ext v
  rfl

theorem deRhamH0_eq_constant_of_diffeomorphic_convex
    {E₁ H₁ M₁ E₂ : Type*}
    [NormedAddCommGroup E₁] [NormedSpace ℝ E₁]
    [NormedAddCommGroup E₂] [NormedSpace ℝ E₂] [FiniteDimensional ℝ E₂]
    [TopologicalSpace H₁] [TopologicalSpace M₁] [ChartedSpace H₁ M₁]
    (I₁ : ModelWithCorners ℝ E₁ H₁) [IsManifold I₁ ∞ M₁]
    (V : TopologicalSpace.Opens E₂) (hconvex : Convex ℝ (V : Set E₂))
    (x₀ : V) (phi : M₁ ≃ₘ⟮I₁, 𝓘(ℝ, E₂)⟯ V)
    (alpha : DeRhamCohomology (I := I₁) (M := M₁) (A := ℝ) 0) :
    ∃ c : ℝ,
      alpha = deRhamConstantH0Class (I0 := I₁) (M0 := M₁) c := by
  let beta := deRhamCohomologyPullbackDiffeomorph
    (𝓘(ℝ, E₂)) I₁ phi.symm 0 alpha
  rcases deRham_convex_open_H0_eq_constant V hconvex x₀ beta with ⟨c, hc⟩
  refine ⟨c, ?_⟩
  calc
    alpha = deRhamCohomologyPullbackDiffeomorph I₁ (𝓘(ℝ, E₂)) phi 0 beta :=
      (deRhamCohomologyPullbackDiffeomorph_comp_symm
        I₁ (𝓘(ℝ, E₂)) phi 0 alpha).symm
    _ = deRhamCohomologyPullbackDiffeomorph I₁ (𝓘(ℝ, E₂)) phi 0
          (deRhamConstantH0Class (I0 := 𝓘(ℝ, E₂)) (M0 := V) c) :=
      congrArg _ hc
    _ = deRhamConstantH0Class (I0 := I₁) (M0 := M₁) c :=
      deRhamCohomologyPullbackDiffeomorph_constant I₁ (𝓘(ℝ, E₂)) phi c

private noncomputable def legacySmoothRealFunctionOfIsLocallyConstant
    {E H M : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    [TopologicalSpace H] [TopologicalSpace M] [ChartedSpace H M]
    (I : ModelWithCorners ℝ E H) [IsManifold I ∞ M]
    (f : M → ℝ) (hf : IsLocallyConstant f) : C^∞⟮I, M; ℝ⟯ where
  val := f
  property := by
    intro x
    exact contMDiffAt_const.congr_of_eventuallyEq (hf.eventually_eq x)

private theorem legacyDeRhamDifferential_locallyConstant_zeroForm_eq_zero
    {E H M : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    [TopologicalSpace H] [TopologicalSpace M] [ChartedSpace H M]
    (I : ModelWithCorners ℝ E H) [IsManifold I ∞ M]
    (f : M → ℝ) (hf : IsLocallyConstant f) :
    deRhamDifferential (I := I) (M := M) (A := ℝ) 0
        (smoothRealFunctionToZeroForm (I0 := I)
          (smoothRealFunctionOfIsLocallyConstant I f hf)) = 0 := by
  apply DifferentialForm.ext
  intro x
  have heq : ∀ᶠ y in 𝓝 x,
      (smoothRealFunctionToZeroForm (I0 := I)
        (smoothRealFunctionOfIsLocallyConstant I f hf)).toFun y =
      (smoothRealFunctionToZeroForm (I0 := I)
        (smoothRealConstantFunction (I0 := I) (f x))).toFun y := by
    filter_upwards [hf.eventually_eq x] with y hy
    simp [smoothRealFunctionOfIsLocallyConstant, hy]
  rw [deRhamDifferential_toFun_eq_of_eventuallyEq
    (I := I)
    (smoothRealFunctionToZeroForm (I0 := I)
      (smoothRealFunctionOfIsLocallyConstant I f hf))
    (smoothRealFunctionToZeroForm (I0 := I)
      (smoothRealConstantFunction (I0 := I) (f x))) heq]
  rw [deRhamDifferential_smoothRealFunctionToZeroForm_const]

theorem deRhamH0_mkQ_eq_iff
    {E H M : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    [TopologicalSpace H] [TopologicalSpace M] [ChartedSpace H M]
    (I : ModelWithCorners ℝ E H) [IsManifold I ∞ M]
    (omega eta : DeRhamClosedForms (I := I) (M := M) (A := ℝ) 0) :
    (DeRhamExactClosedForms (I := I) (M := M) (A := ℝ) 0).mkQ omega =
        (DeRhamExactClosedForms (I := I) (M := M) (A := ℝ) 0).mkQ eta ↔
      omega = eta := by
  simp only [Submodule.mkQ_apply]
  rw [Submodule.Quotient.eq]
  simp [DeRhamExactClosedForms, DeRhamExactForms, sub_eq_zero]

set_option synthInstance.maxHeartbeats 100000 in
theorem deRhamConstantH0Class_sub
    {E H M : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    [TopologicalSpace H] [TopologicalSpace M] [ChartedSpace H M]
    (I : ModelWithCorners ℝ E H) [IsManifold I ∞ M]
    (c d : ℝ) :
    deRhamConstantH0Class (I0 := I) (M0 := M) c -
        deRhamConstantH0Class (I0 := I) (M0 := M) d =
      deRhamConstantH0Class (I0 := I) (M0 := M) (c - d) := by
  simp only [deRhamConstantH0Class, ← map_sub]
  apply congrArg
    (DeRhamExactClosedForms (I := I) (M := M) (A := ℝ) 0).mkQ
  apply Subtype.ext
  apply DifferentialForm.ext
  intro x
  ext q
  rw [show q = (fun i : Fin 0 => nomatch i) from Subsingleton.elim _ _]
  simp [deRhamConstantZeroClosedForm, smoothRealFunctionToZeroForm,
    smoothRealConstantFunction]
  change c - d = c - d
  rfl

def annularOpposite (v : Circle) : Circle :=
  (stereographic' 1 v).symm 0

theorem annularOpposite_mem_source (v : Circle) :
    annularOpposite v ∈ (stereographic' 1 v).source := by
  apply (stereographic' 1 v).map_target
  simp

theorem annularPunctureChart_opposite (v : Circle) :
    stereographic' 1 v (annularOpposite v) = 0 := by
  apply (stereographic' 1 v).right_inv
  simp

theorem annularOpposite_ne (v : Circle) : annularOpposite v ≠ v := by
  intro h
  have := annularOpposite_mem_source v
  rw [stereographic'_source] at this
  exact this h

theorem euclideanFinOne_eq_zero_iff
    (x : EuclideanSpace ℝ (Fin 1)) : x = 0 ↔ x 0 = 0 := by
  constructor
  · intro h
    rw [h]
    rfl
  · intro h
    apply WithLp.ofLp_injective
    funext i
    fin_cases i
    exact h

theorem stereographic_eq_zero_iff (v x : Circle)
    (hx : x ∈ (stereographic' 1 v).source) :
    stereographic' 1 v x = 0 ↔ x = annularOpposite v := by
  constructor
  · intro hzero
    apply (stereographic' 1 v).injOn hx (annularOpposite_mem_source v)
    rw [hzero, annularPunctureChart_opposite]
  · intro h
    rw [h, annularPunctureChart_opposite]

def annularPositiveTarget :
    TopologicalSpace.Opens (EuclideanSpace ℝ (Fin 1) × ℝ) where
  carrier := {p | 0 < p.1 0}
  is_open' := isOpen_lt continuous_const
    ((PiLp.continuous_apply 2 (fun _ : Fin 1 => ℝ) 0).comp continuous_fst)

def annularNegativeTarget :
    TopologicalSpace.Opens (EuclideanSpace ℝ (Fin 1) × ℝ) where
  carrier := {p | p.1 0 < 0}
  is_open' := isOpen_lt
    ((PiLp.continuous_apply 2 (fun _ : Fin 1 => ℝ) 0).comp continuous_fst)
    continuous_const

theorem annularPositiveTarget_convex :
    Convex ℝ (annularPositiveTarget : Set (EuclideanSpace ℝ (Fin 1) × ℝ)) := by
  change Convex ℝ {p : EuclideanSpace ℝ (Fin 1) × ℝ | 0 < p.1 0}
  apply convex_halfSpace_gt
  exact ⟨by intro x y; simp, by intro c x; simp⟩

theorem annularNegativeTarget_convex :
    Convex ℝ (annularNegativeTarget : Set (EuclideanSpace ℝ (Fin 1) × ℝ)) := by
  change Convex ℝ {p : EuclideanSpace ℝ (Fin 1) × ℝ | p.1 0 < 0}
  apply convex_halfSpace_lt
  exact ⟨by intro x y; simp, by intro c x; simp⟩

theorem annularPositiveTarget_nonempty :
    (annularPositiveTarget : Set (EuclideanSpace ℝ (Fin 1) × ℝ)).Nonempty := by
  refine ⟨(WithLp.toLp 2 (fun _ : Fin 1 => (1 : ℝ)), 0), ?_⟩
  simp [annularPositiveTarget]

theorem annularNegativeTarget_nonempty :
    (annularNegativeTarget : Set (EuclideanSpace ℝ (Fin 1) × ℝ)).Nonempty := by
  refine ⟨(WithLp.toLp 2 (fun _ : Fin 1 => (-1 : ℝ)), 0), ?_⟩
  simp [annularNegativeTarget]

def annularPositiveComponent (v : Circle) :
    TopologicalSpace.Opens (Circle × ℝ) where
  carrier :=
    (deRham_boundarylessExtendedChart AnnularCylinderModel
      (annularPunctureChart v)).source ∩
      deRham_boundarylessExtendedChart AnnularCylinderModel
        (annularPunctureChart v) ⁻¹' annularPositiveTarget
  is_open' :=
    (deRham_boundarylessExtendedChart AnnularCylinderModel
      (annularPunctureChart v)).isOpen_inter_preimage annularPositiveTarget.2

def annularNegativeComponent (v : Circle) :
    TopologicalSpace.Opens (Circle × ℝ) where
  carrier :=
    (deRham_boundarylessExtendedChart AnnularCylinderModel
      (annularPunctureChart v)).source ∩
      deRham_boundarylessExtendedChart AnnularCylinderModel
        (annularPunctureChart v) ⁻¹' annularNegativeTarget
  is_open' :=
    (deRham_boundarylessExtendedChart AnnularCylinderModel
      (annularPunctureChart v)).isOpen_inter_preimage annularNegativeTarget.2

theorem mem_annularPositiveComponent_iff (v : Circle) (p : Circle × ℝ) :
    p ∈ (annularPositiveComponent v : Set (Circle × ℝ)) ↔
      p.1 ≠ v ∧ 0 < (stereographic' 1 v p.1) 0 := by
  simp only [annularPositiveComponent]
  simp [annularPunctureChart, annularPositiveTarget, AnnularCylinderModel,
    deRham_boundarylessExtendedChart]
  intro hpos
  constructor
  · rintro ⟨hsource, _⟩
    change p.1 ∈ ({v}ᶜ : Set Circle) ∧ p.2 ∈ (Set.univ : Set ℝ) at hsource
    simpa using hsource.1
  · intro hpv
    constructor
    · change p.1 ∈ ({v}ᶜ : Set Circle) ∧ p.2 ∈ (Set.univ : Set ℝ)
      exact ⟨by simpa using hpv, Set.mem_univ _⟩
    · exact Set.mem_univ _

theorem mem_annularNegativeComponent_iff (v : Circle) (p : Circle × ℝ) :
    p ∈ (annularNegativeComponent v : Set (Circle × ℝ)) ↔
      p.1 ≠ v ∧ (stereographic' 1 v p.1) 0 < 0 := by
  simp only [annularNegativeComponent]
  simp [annularPunctureChart, annularNegativeTarget, AnnularCylinderModel,
    deRham_boundarylessExtendedChart]
  intro hneg
  constructor
  · rintro ⟨hsource, _⟩
    change p.1 ∈ ({v}ᶜ : Set Circle) ∧ p.2 ∈ (Set.univ : Set ℝ) at hsource
    simpa using hsource.1
  · intro hpv
    constructor
    · change p.1 ∈ ({v}ᶜ : Set Circle) ∧ p.2 ∈ (Set.univ : Set ℝ)
      exact ⟨by simpa using hpv, Set.mem_univ _⟩
    · exact Set.mem_univ _

theorem mem_annularPunctureOpen_iff (v : Circle) (p : Circle × ℝ) :
    p ∈ (annularPunctureOpen v : Set (Circle × ℝ)) ↔ p.1 ≠ v := by
  simp only [annularPunctureOpen, annularPunctureChart,
    OpenPartialHomeomorph.prod_source, stereographic'_source,
    OpenPartialHomeomorph.refl_source]
  change (p.1 ∈ ({v}ᶜ : Set Circle) ∧ p.2 ∈ (Set.univ : Set ℝ)) ↔ p.1 ≠ v
  simp

def annularDoublePunctureOpen (v : Circle) :
    TopologicalSpace.Opens (Circle × ℝ) :=
  annularPunctureOpen v ⊓ annularPunctureOpen (annularOpposite v)

theorem annularComponents_cover_doublePuncture (v : Circle) :
    annularPositiveComponent v ⊔ annularNegativeComponent v =
      annularDoublePunctureOpen v := by
  apply le_antisymm
  · apply sup_le
    · intro p hp
      have hpSet : p ∈ (annularPositiveComponent v : Set (Circle × ℝ)) := hp
      rw [mem_annularPositiveComponent_iff] at hpSet
      change p ∈ annularPunctureOpen v ∧
        p ∈ annularPunctureOpen (annularOpposite v)
      have hpv : p ∈ annularPunctureOpen v :=
        (mem_annularPunctureOpen_iff v p).mpr hpSet.1
      refine ⟨hpv, ?_⟩
      apply (mem_annularPunctureOpen_iff (annularOpposite v) p).mpr
      intro hopposite
      rw [hopposite, annularPunctureChart_opposite] at hpSet
      have : (0 : ℝ) < 0 := by simpa using hpSet.2
      exact (lt_irrefl 0) this
    · intro p hp
      have hpSet : p ∈ (annularNegativeComponent v : Set (Circle × ℝ)) := hp
      rw [mem_annularNegativeComponent_iff] at hpSet
      change p ∈ annularPunctureOpen v ∧
        p ∈ annularPunctureOpen (annularOpposite v)
      have hpv : p ∈ annularPunctureOpen v :=
        (mem_annularPunctureOpen_iff v p).mpr hpSet.1
      refine ⟨hpv, ?_⟩
      apply (mem_annularPunctureOpen_iff (annularOpposite v) p).mpr
      intro hopposite
      rw [hopposite, annularPunctureChart_opposite] at hpSet
      have : (0 : ℝ) < 0 := by simpa using hpSet.2
      exact (lt_irrefl 0) this
  · intro p hp
    change p ∈ annularPunctureOpen v ∧
      p ∈ annularPunctureOpen (annularOpposite v) at hp
    have hp' : p.1 ≠ v ∧ p.1 ≠ annularOpposite v := by
      exact ⟨(mem_annularPunctureOpen_iff v p).mp hp.1,
        (mem_annularPunctureOpen_iff (annularOpposite v) p).mp hp.2⟩
    change p ∈ annularPositiveComponent v ∨ p ∈ annularNegativeComponent v
    have hsource : p.1 ∈ (stereographic' 1 v).source := by
      simpa [stereographic'_source] using hp'.1
    have hcoord : (stereographic' 1 v p.1) 0 ≠ 0 := by
      intro hzero
      apply hp'.2
      apply (stereographic_eq_zero_iff v p.1 hsource).mp
      exact (euclideanFinOne_eq_zero_iff _).mpr hzero
    rcases lt_or_gt_of_ne hcoord with hneg | hpos
    · right
      show p ∈ (annularNegativeComponent v : Set (Circle × ℝ))
      exact (mem_annularNegativeComponent_iff v p).mpr ⟨hp'.1, hneg⟩
    · left
      show p ∈ (annularPositiveComponent v : Set (Circle × ℝ))
      exact (mem_annularPositiveComponent_iff v p).mpr ⟨hp'.1, hpos⟩

theorem annularComponents_disjoint (v : Circle) :
    annularPositiveComponent v ⊓ annularNegativeComponent v = ⊥ := by
  apply le_antisymm
  · intro p hp
    change p ∈ annularPositiveComponent v ∧ p ∈ annularNegativeComponent v at hp
    have hpPos : p ∈ (annularPositiveComponent v : Set (Circle × ℝ)) := hp.1
    have hpNeg : p ∈ (annularNegativeComponent v : Set (Circle × ℝ)) := hp.2
    rw [mem_annularPositiveComponent_iff] at hpPos
    rw [mem_annularNegativeComponent_iff] at hpNeg
    have : False := by linarith [hpPos.2, hpNeg.2]
    exact this.elim
  · intro p hp
    change p ∈ (∅ : Set (Circle × ℝ)) at hp
    exact hp.elim

theorem annularPositiveComponent_le_doublePuncture (v : Circle) :
    annularPositiveComponent v ≤ annularDoublePunctureOpen v := by
  rw [← annularComponents_cover_doublePuncture v]
  exact le_sup_left

theorem annularNegativeComponent_le_doublePuncture (v : Circle) :
    annularNegativeComponent v ≤ annularDoublePunctureOpen v := by
  rw [← annularComponents_cover_doublePuncture v]
  exact le_sup_right

def annularOverlapPositiveSet (v : Circle) :
    Set (annularDoublePunctureOpen v) :=
  {x | (x.1 : Circle × ℝ) ∈ (annularPositiveComponent v : Set (Circle × ℝ))}

theorem annularOverlapPositiveSet_isClopen (v : Circle) :
    IsClopen (annularOverlapPositiveSet v) := by
  have hopen : IsOpen (annularOverlapPositiveSet v) :=
    (annularPositiveComponent v).2.preimage continuous_subtype_val
  refine ⟨?_, hopen⟩
  rw [← isOpen_compl_iff]
  have heq : (annularOverlapPositiveSet v)ᶜ =
      {x : annularDoublePunctureOpen v |
        (x.1 : Circle × ℝ) ∈
          (annularNegativeComponent v : Set (Circle × ℝ))} := by
    ext x
    change
      (¬(x.1 : Circle × ℝ) ∈
        (annularPositiveComponent v : Set (Circle × ℝ))) ↔
      (x.1 : Circle × ℝ) ∈
        (annularNegativeComponent v : Set (Circle × ℝ))
    rw [mem_annularPositiveComponent_iff,
      mem_annularNegativeComponent_iff]
    have hxpuncture :
        (x.1 : Circle × ℝ).1 ≠ v ∧
          (x.1 : Circle × ℝ).1 ≠ annularOpposite v := by
      have hxproperty := x.property
      change (x.1 : Circle × ℝ) ∈ annularPunctureOpen v ∧
        (x.1 : Circle × ℝ) ∈ annularPunctureOpen (annularOpposite v) at hxproperty
      exact ⟨(mem_annularPunctureOpen_iff v x.1).mp hxproperty.1,
        (mem_annularPunctureOpen_iff (annularOpposite v) x.1).mp hxproperty.2⟩
    have hsource : (x.1 : Circle × ℝ).1 ∈ (stereographic' 1 v).source := by
      simpa [stereographic'_source] using hxpuncture.1
    have hcoord :
        (stereographic' 1 v (x.1 : Circle × ℝ).1) 0 ≠ 0 := by
      intro hzero
      apply hxpuncture.2
      apply (stereographic_eq_zero_iff v _ hsource).mp
      exact (euclideanFinOne_eq_zero_iff _).mpr hzero
    constructor
    · intro hnot
      refine ⟨hxpuncture.1, ?_⟩
      have hnpos : ¬0 < (stereographic' 1 v (x.1 : Circle × ℝ).1) 0 :=
        fun hpos => hnot ⟨hxpuncture.1, hpos⟩
      exact lt_of_le_of_ne (le_of_not_gt hnpos) hcoord
    · rintro ⟨_, hneg⟩ ⟨_, hpos⟩
      linarith
  rw [heq]
  exact (annularNegativeComponent v).2.preimage continuous_subtype_val

noncomputable def annularOverlapStepFunction (v : Circle)
    (x : annularDoublePunctureOpen v) : ℝ :=
  by
    classical
    exact if x ∈ annularOverlapPositiveSet v then 1 else 0

theorem annularOverlapStepFunction_isLocallyConstant (v : Circle) :
    IsLocallyConstant (annularOverlapStepFunction v) := by
  classical
  rw [IsLocallyConstant.iff_eventually_eq]
  intro x
  by_cases hx : x ∈ annularOverlapPositiveSet v
  · filter_upwards [(annularOverlapPositiveSet_isClopen v).2.mem_nhds hx] with y hy
    simp [annularOverlapStepFunction, hx, hy]
  · have hxc : x ∈ (annularOverlapPositiveSet v)ᶜ := hx
    filter_upwards [((annularOverlapPositiveSet_isClopen v).1.isOpen_compl.mem_nhds hxc)]
      with y hy
    have hynot : y ∉ annularOverlapPositiveSet v := hy
    simp [annularOverlapStepFunction, hx, hynot]

noncomputable def annularOverlapStepClosedForm (v : Circle) :
    DeRhamClosedForms (I := AnnularCylinderModel)
      (M := annularDoublePunctureOpen v) (A := ℝ) 0 :=
  ⟨smoothRealFunctionToZeroForm (I0 := AnnularCylinderModel)
      (smoothRealFunctionOfIsLocallyConstant AnnularCylinderModel
        (annularOverlapStepFunction v)
        (annularOverlapStepFunction_isLocallyConstant v)),
    deRhamDifferential_locallyConstant_zeroForm_eq_zero
      (I0 := AnnularCylinderModel) (annularOverlapStepFunction v)
      (annularOverlapStepFunction_isLocallyConstant v)⟩

noncomputable def annularOverlapStepClass (v : Circle) :
    DeRhamCohomology (I := AnnularCylinderModel)
      (M := annularDoublePunctureOpen v) (A := ℝ) 0 :=
  (DeRhamExactClosedForms (I := AnnularCylinderModel)
    (M := annularDoublePunctureOpen v) (A := ℝ) 0).mkQ
      (annularOverlapStepClosedForm v)

theorem annularOverlapStepClosedForm_restrict_positive (v : Circle) :
    deRhamClosedFormsRestrictionOfLE (I := AnnularCylinderModel) (A := ℝ)
        (annularPositiveComponent_le_doublePuncture v) 0
        (annularOverlapStepClosedForm v) =
      deRhamConstantZeroClosedForm (I0 := AnnularCylinderModel)
        (M0 := annularPositiveComponent v) 1 := by
  classical
  apply Subtype.ext
  apply DifferentialForm.ext
  intro x
  ext q
  rw [show q = (fun i : Fin 0 => nomatch i) from Subsingleton.elim _ _]
  simp only [deRhamClosedFormsRestrictionOfLE, restrictSmoothFormsOfLE,
    annularOverlapStepClosedForm,
    smoothRealFunctionToZeroForm, smoothRealFunctionOfIsLocallyConstant,
    deRhamConstantZeroClosedForm, smoothRealConstantFunction,
    ContinuousAlternatingMap.constOfIsEmpty_apply]
  have hx : TopologicalSpace.Opens.inclusion
      (annularPositiveComponent_le_doublePuncture v) x ∈
        annularOverlapPositiveSet v := x.property
  change
    (if TopologicalSpace.Opens.inclusion
        (annularPositiveComponent_le_doublePuncture v) x ∈
          annularOverlapPositiveSet v then 1 else 0) = 1
  simp [hx]

theorem annularOverlapStepClosedForm_restrict_negative (v : Circle) :
    deRhamClosedFormsRestrictionOfLE (I := AnnularCylinderModel) (A := ℝ)
        (annularNegativeComponent_le_doublePuncture v) 0
        (annularOverlapStepClosedForm v) =
      deRhamConstantZeroClosedForm (I0 := AnnularCylinderModel)
        (M0 := annularNegativeComponent v) 0 := by
  classical
  apply Subtype.ext
  apply DifferentialForm.ext
  intro x
  ext q
  rw [show q = (fun i : Fin 0 => nomatch i) from Subsingleton.elim _ _]
  simp only [deRhamClosedFormsRestrictionOfLE, restrictSmoothFormsOfLE,
    annularOverlapStepClosedForm,
    smoothRealFunctionToZeroForm, smoothRealFunctionOfIsLocallyConstant,
    deRhamConstantZeroClosedForm, smoothRealConstantFunction,
    ContinuousAlternatingMap.constOfIsEmpty_apply]
  have hx : TopologicalSpace.Opens.inclusion
      (annularNegativeComponent_le_doublePuncture v) x ∉
        annularOverlapPositiveSet v := by
    intro hxpos
    have hxPosAmbient : (x.1 : Circle × ℝ) ∈
        (annularPositiveComponent v : Set (Circle × ℝ)) := hxpos
    have hxNegAmbient : (x.1 : Circle × ℝ) ∈
        (annularNegativeComponent v : Set (Circle × ℝ)) := x.property
    have hmem : (x.1 : Circle × ℝ) ∈
        (annularPositiveComponent v ⊓ annularNegativeComponent v :
          TopologicalSpace.Opens (Circle × ℝ)) := ⟨hxPosAmbient, hxNegAmbient⟩
    rw [annularComponents_disjoint v] at hmem
    exact hmem
  change
    (if TopologicalSpace.Opens.inclusion
        (annularNegativeComponent_le_doublePuncture v) x ∈
          annularOverlapPositiveSet v then 1 else 0) = 0
  simp [hx]

theorem annularOverlapStepClass_restrict_positive (v : Circle) :
    deRhamCohomologyRestrictionOfLE (I := AnnularCylinderModel) (A := ℝ)
        (annularPositiveComponent_le_doublePuncture v) 0
        (annularOverlapStepClass v) =
      deRhamConstantH0Class (I0 := AnnularCylinderModel)
        (M0 := annularPositiveComponent v) 1 := by
  simp only [annularOverlapStepClass, deRhamCohomologyRestrictionOfLE,
    deRhamConstantH0Class]
  change
    (DeRhamExactClosedForms (I := AnnularCylinderModel)
      (M := annularPositiveComponent v) (A := ℝ) 0).mkQ
        (deRhamClosedFormsRestrictionOfLE (I := AnnularCylinderModel) (A := ℝ)
          (annularPositiveComponent_le_doublePuncture v) 0
          (annularOverlapStepClosedForm v)) = _
  rw [annularOverlapStepClosedForm_restrict_positive]

theorem annularOverlapStepClass_restrict_negative (v : Circle) :
    deRhamCohomologyRestrictionOfLE (I := AnnularCylinderModel) (A := ℝ)
        (annularNegativeComponent_le_doublePuncture v) 0
        (annularOverlapStepClass v) =
      deRhamConstantH0Class (I0 := AnnularCylinderModel)
